{
  "name": "editor",
  "projectType": "application",
  "sourceRoot": "editor/src",
  "tags": ["scope:editor", "type:app"],
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "npm --prefix editor run dev"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["editor"],
      "outputs": ["{projectRoot}/dist"],
      "options": {
        "command": "npm --prefix editor run build"
      }
    },
    "types": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["editor"],
      "outputs": ["{workspaceRoot}/.cache/tsbuildinfo/editor"],
      "options": {
        "command": "npm --prefix editor run types"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "dependsOn": ["types"],
      "cache": true,
      "inputs": ["editor"],
      "outputs": [],
      "options": {
        "command": "npm --prefix editor run test"
      }
    }
  }
}
