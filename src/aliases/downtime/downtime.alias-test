!downtime
---
re:not configured
---
name: blocks without server config

!downtime
---
re:disabled on this server
---
name: rejects disabled downtime command
vars:
  svars:
    westmarch_config: "dddd1000-1000-1000-1000-100000000000"
  gvars:
    dddd1000-1000-1000-1000-100000000000: |
      subsystems = {
          "downtime": {"enabled": False},
      }

!downtime help
---
re:Usage[\s\S]*downtime <amount>[\s\S]*reset yes
---
name: shows downtime help when enabled
vars:
  svars:
    westmarch_config: "dddd1001-1001-1001-1001-100000000001"
  gvars:
    dddd1001-1001-1001-1001-100000000001: |
      subsystems = {
          "downtime": {
              "enabled": True,
              "config": {
                  "mode": "tracked",
                  "max_workdays": None,
                  "acquisition": "manual",
                  "workday_hours": 8,
                  "workweek_days": 5,
              },
          },
      }

!downtime
---
re:Downtime tracking is off
---
name: default downtime mode is off when config omitted
vars:
  svars:
    westmarch_config: "dddd1005-1005-1005-1005-100000000005"
  gvars:
    dddd1005-1005-1005-1005-100000000005: |
      subsystems = {
          "downtime": {"enabled": True},
      }

!downtime
---
re:\*\*3 workdays\*\* available[\s\S]*Manual mode
---
name: shows current downtime balance
vars:
  cvars:
    wg_downtime: "3"
  svars:
    westmarch_config: "dddd1002-1002-1002-1002-100000000002"
  gvars:
    dddd1002-1002-1002-1002-100000000002: |
      subsystems = {
          "downtime": {
              "enabled": True,
              "config": {"mode": "manual", "max_workdays": None, "acquisition": "manual"},
          },
      }

!downtime 2
---
re:gained \*\*2\*\* workdays[\s\S]*\*\*1\*\* -> \*\*3\*\*[\s\S]*Tracked mode
---
name: adds downtime workdays
vars:
  cvars:
    wg_downtime: "1"
  svars:
    westmarch_config: "dddd1003-1003-1003-1003-100000000003"
  gvars:
    dddd1003-1003-1003-1003-100000000003: |
      subsystems = {
          "downtime": {
              "enabled": True,
              "config": {"mode": "tracked", "max_workdays": None, "acquisition": "manual"},
          },
      }

!downtime spend 2
---
re:Could not spend \*\*2\*\* workdays[\s\S]*only has \*\*1\*\*
---
name: rejects spending unavailable workdays
vars:
  cvars:
    wg_downtime: "1"
  svars:
    westmarch_config: "dddd1003-1003-1003-1003-100000000003"
  gvars:
    dddd1003-1003-1003-1003-100000000003: |
      subsystems = {
          "downtime": {
              "enabled": True,
              "config": {"mode": "tracked", "max_workdays": None, "acquisition": "manual"},
          },
      }

!downtime reset
---
re:Confirm with `!downtime reset yes`
---
name: reset requires confirmation
vars:
  cvars:
    wg_downtime: "4"
  svars:
    westmarch_config: "dddd1003-1003-1003-1003-100000000003"
  gvars:
    dddd1003-1003-1003-1003-100000000003: |
      subsystems = {
          "downtime": {
              "enabled": True,
              "config": {"mode": "tracked", "max_workdays": None, "acquisition": "manual"},
          },
      }

!downtime reset yes
---
re:Downtime balance reset[\s\S]*\*\*0 workdays\*\* available
---
name: reset clears downtime balance
vars:
  cvars:
    wg_downtime: "4"
  svars:
    westmarch_config: "dddd1003-1003-1003-1003-100000000003"
  gvars:
    dddd1003-1003-1003-1003-100000000003: |
      subsystems = {
          "downtime": {
              "enabled": True,
              "config": {"mode": "tracked", "max_workdays": None, "acquisition": "manual"},
          },
      }

!downtime
---
re:Downtime tracking is off
---
name: downtime off mode does not use cvar ledger
vars:
  svars:
    westmarch_config: "dddd1004-1004-1004-1004-100000000004"
  gvars:
    dddd1004-1004-1004-1004-100000000004: |
      subsystems = {
          "downtime": {
              "enabled": True,
              "config": {"mode": "off", "max_workdays": None, "acquisition": "manual"},
          },
      }
