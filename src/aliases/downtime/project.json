{
  "name": "avrae-aliases-downtime",
  "projectType": "application",
  "sourceRoot": "src/aliases/downtime",
  "tags": ["scope:avrae", "type:aliases"],
  "implicitDependencies": [
    "avrae-sourcemaps",
    "avrae-gvar-configs",
    "avrae-gvar-utils-core",
    "avrae-gvar-utils-config",
    "avrae-gvar-utils-display",
    "avrae-gvar-utils-economy",
    "avrae-gvar-utils-pc"
  ],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "avraeAliasBase",
        "{workspaceRoot}/src/gvars/utils/economy/**/*",
        "{workspaceRoot}/src/gvars/utils/pc/**/*"
      ],
      "outputs": [],
      "options": {
        "command": "avrae-ls --log-level INFO --run-tests src/aliases/downtime"
      }
    }
  }
}
