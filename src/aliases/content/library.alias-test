!library
---
re:not configured
---
name: blocks without server config

!library
---
re:Provide a library topic
---
name: enabled library asks for manual topic by default
vars:
  svars:
    westmarch_config: "dddddddd-dddd-dddd-dddd-dddddddddddd"
  gvars:
    dddddddd-dddd-dddd-dddd-dddddddddddd: |
      subsystems = {
          "content": {
              "enabled": True,
              "commands": {"library": True, "read": False},
          },
      }

!library
---
re:disabled on this server
---
name: rejects disabled library command
vars:
  svars:
    westmarch_config: "eeeeeeee-eeee-eeee-eeee-eeeeeeeeeeee"
  gvars:
    eeeeeeee-eeee-eeee-eeee-eeeeeeeeeeee: |
      subsystems = {
          "content": {
              "enabled": True,
              "commands": {"library": False, "read": False},
          },
      }

!library forest comprehend -b 100
---
re:Topics:[\s\S]*Oakwood Almanac[\s\S]*Next step
---
name: library searches configured world_data books
vars:
  svars:
    westmarch_config: "cccc1000-1000-1000-1000-100000000001"
  gvars:
    cccc1000-1000-1000-1000-100000000001: |
      subsystems = {
          "content": {
              "enabled": True,
              "commands": {"library": True, "read": True},
              "config": {"library_topic_source": "manual", "allowed_topics": []},
          },
      }
      policies = {"content": {"enforce_library_cooldowns": False, "enforce_read_cooldowns": False}}
      world_data = {
          "books": [
              {
                  "name": "Oakwood Almanac",
                  "author": "Mira",
                  "written": "1492 DR",
                  "rarity": "common",
                  "language": "Common",
                  "type": "original",
                  "description": "A practical guide to oak groves and forest roads.",
                  "tags": ["forest", "history"],
              },
          ],
      }
character:
  cvars:
    languages: '["common"]'
    wg_book_comprehension: "{}"
  skills:
    investigation:
      value: 12
      prof: 1
      bonus: 0
      adv: null
    history:
      value: 12
      prof: 1
      bonus: 0
      adv: null
    nature:
      value: 12
      prof: 1
      bonus: 0
      adv: null
