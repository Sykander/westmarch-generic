!weather forest
---
re:\*\*forest\*\*[\s\S]*Cool mist hangs beneath the trees\.
---
name: weather shows configured area forecast
vars:
  svars:
    westmarch_config: "ffff2020-2020-2020-2020-202020202020"
  gvars:
    ffff2020-2020-2020-2020-202020202020: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"weather": True}},
      }
      world_data = {
          "weather": {
              "by_area": {
                  "forest": {"default": ["Cool mist hangs beneath the trees."]},
              },
          },
      }

!weather help
---
re:Show the current regional weather[\s\S]*`forest`
---
name: weather help lists configured areas
vars:
  svars:
    westmarch_config: "ffff2020-2020-2020-2020-202020202020"
  gvars:
    ffff2020-2020-2020-2020-202020202020: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"weather": True}},
      }
      world_data = {
          "weather": {
              "by_area": {
                  "forest": {"default": ["Cool mist hangs beneath the trees."]},
              },
          },
      }
