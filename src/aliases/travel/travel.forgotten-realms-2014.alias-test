!location
---
re:Waterdeep[\s\S]*Activities
---
name: Forgotten Realms location command loads starter locations
vars:
  svars:
    westmarch_config: "aaaa2f14-2014-2014-2014-000000000005"
  gvars:
    aaaa2f14-2014-2014-2014-000000000005: |
      using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
      display = {"name": "Forgotten Realms", "footer": "Forgotten Realms"}
      policies = {"display": {"footer_behaviour": "string"}}
      subsystems = {"travel": {"enabled": True, "commands": {"travel": True, "location": True}, "config": {"show_shops_on_travel": False}}}
      world_data = {"default_location": "waterdeep", "locations_gvar_id": env.gvars.forgotten_realms_2014_locations, "paths_gvar_id": env.gvars.forgotten_realms_2014_paths}

!time
---
re:Calendar of Harptos[\s\S]*1492 DR
---
name: Forgotten Realms time command loads starter calendar
vars:
  svars:
    westmarch_config: "aaaa2f14-2014-2014-2014-000000000006"
  gvars:
    aaaa2f14-2014-2014-2014-000000000006: |
      display = {"name": "Forgotten Realms", "footer": "Forgotten Realms"}
      policies = {"display": {"footer_behaviour": "string"}}
      subsystems = {"travel": {"enabled": True, "commands": {"time": True}}}
      world_data = {"calendars": {"primary": {"id": "primary", "name": "Calendar of Harptos", "epoch_unix": 0, "tick_rate": 0, "seconds_per_day": 86400, "start_year": 1492, "months": [{"name": "Hammer", "days": 30}], "weekdays": ["First-day"], "display_format": "{weekday}, {day} {month} {year} DR {hour}:{minute}"}}}

!weather
---
re:coast[\s\S]*Sea of Swords
---
name: Forgotten Realms weather command resolves Waterdeep coast weather
vars:
  svars:
    westmarch_config: "aaaa2f14-2014-2014-2014-000000000007"
  gvars:
    aaaa2f14-2014-2014-2014-000000000007: |
      using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
      display = {"name": "Forgotten Realms", "footer": "Forgotten Realms"}
      policies = {"display": {"footer_behaviour": "string"}}
      subsystems = {"travel": {"enabled": True, "commands": {"weather": True}}}
      world_data = {"default_location": "waterdeep", "locations_gvar_id": env.gvars.forgotten_realms_2014_locations, "weather": {"by_area": {"coast": {"default": ["Salt wind rolls in from the Sea of Swords."]}}}}
