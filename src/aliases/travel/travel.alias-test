!travel
---
re:not configured
---
name: blocks without server config

!travel
---
re:disabled on this server
---
name: rejects disabled travel command
vars:
  svars:
    westmarch_config: "aaaa2000-2000-2000-2000-200000000000"
  gvars:
    aaaa2000-2000-2000-2000-200000000000: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": False}},
      }

!travel help
---
re:Usage[\s\S]*travel next[\s\S]*horse
---
name: shows help when enabled
vars:
  svars:
    westmarch_config: "aaaa2001-2001-2001-2001-200000000001"
  gvars:
    aaaa2001-2001-2001-2001-200000000001: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {"river_town": {"name": "River Town"}},
          "paths": [],
      }

!travel
---
re:River Town[\s\S]*busy quay
---
name: bare travel shows current location
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000002"
  gvars:
    aaaa2002-2002-2002-2002-200000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town", "description": "A busy quay.", "commands": {"enc": ["road"]}},
              "oakwood": {"name": "Oakwood Forest", "commands": {"enc": ["forest"]}},
          },
          "paths": [
              {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]},
          ],
      }

!travel
---
re:River Town(?![\s\S]*Shops)(?![\s\S]*General Store)
---
name: bare travel can hide local shop prices through travel config
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000024"
  gvars:
    aaaa2002-2002-2002-2002-200000000024: |
      subsystems = {
          "travel": {
              "enabled": True,
              "commands": {"travel": True, "location": True},
              "config": {"show_shops_on_travel": False},
          },
          "economy": {"enabled": True, "commands": {"buy": True, "sell": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town", "commands": {"buy": True, "sell": True}},
          },
      }
      shops = {
          "general": {
              "id": "general",
              "name": "General Store",
              "location_id": "river_town",
              "accepts_sells": True,
              "stock": [{"item": "Rope, Hemp (50 ft)", "price": {"gold": 2}}],
          },
      }

!travel Oakwood
---
re:River Town[\s\S]*Oakwood Forest[\s\S]*!enc forest[\s\S]*track this journey
---
name: route preview shows journey and tracking hint
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000002"
  gvars:
    aaaa2002-2002-2002-2002-200000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town", "commands": {"enc": ["road"]}},
              "oakwood": {"name": "Oakwood Forest", "commands": {"enc": ["forest"]}},
          },
          "paths": [
              {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]},
          ],
      }

!travel Oakwood riding_horse
---
re:Oakwood Forest[\s\S]*Ride the old road[\s\S]*horse track
---
name: route preview resolves specific transport alias to category
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000022"
  gvars:
    aaaa2002-2002-2002-2002-200000000022: |
      subsystems = {
          "travel": {
              "enabled": True,
              "commands": {"travel": True, "location": True},
              "config": {"transport_icons": {"walk": "W", "horse": "H", "fly": "F", "boat": "B"}},
          },
      }
      world_data = {
          "default_location": "river_town",
          "transport": {
              "walk": {"name": "Walking", "default": True, "aliases": ["walking"]},
              "horse": {"name": "Horse or mount", "aliases": ["riding_horse", "warhorse", "pony"]},
          },
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
          },
          "paths": [
              {"from": "river_town", "to": "oakwood", "requirements": {"transport": "horse"}, "steps": [{"type": "proceed", "description": "Ride the old road."}]},
          ],
      }

!travel Oakwood unicorn
---
re:Unknown transport \*\*unicorn\*\*
---
name: trailing unknown transport is reported clearly
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000023"
  gvars:
    aaaa2002-2002-2002-2002-200000000023: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "transport": {
              "walk": {"name": "Walking", "default": True, "aliases": ["walking"]},
              "horse": {"name": "Horse or mount", "aliases": ["riding_horse", "warhorse", "pony"]},
          },
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
          },
          "paths": [],
      }

!travel Island
---
re:Could not find a route
---
name: route without required extra transport fails
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000024"
  gvars:
    aaaa2002-2002-2002-2002-200000000024: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "transport": {
              "walk": {"name": "Walking", "default": True},
              "boat": {"name": "Boat"},
          },
          "locations": {
              "river_town": {"name": "River Town"},
              "island": {"name": "Island"},
          },
          "paths": [
              {"from": "river_town", "to": "island", "requirements": {"transport": ["walk", "boat"]}, "steps": [{"type": "encounter", "biome": "river"}]},
          ],
      }

!travel Island boat
---
re:Island[\s\S]*!enc river[\s\S]*Island" boat track
---
name: route combines default and explicit transport availability
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000024"
  gvars:
    aaaa2002-2002-2002-2002-200000000024: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "transport": {
              "walk": {"name": "Walking", "default": True},
              "boat": {"name": "Boat"},
          },
          "locations": {
              "river_town": {"name": "River Town"},
              "island": {"name": "Island"},
          },
          "paths": [
              {"from": "river_town", "to": "island", "requirements": {"transport": ["walk", "boat"]}, "steps": [{"type": "encounter", "biome": "river"}]},
          ],
      }

!travel Island
---
re:Island[\s\S]*!enc river
---
name: route uses westmarch_travel_transport cvar availability
vars:
  cvars:
    westmarch_travel_transport: '["boat"]'
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000024"
  gvars:
    aaaa2002-2002-2002-2002-200000000024: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "transport": {
              "walk": {"name": "Walking", "default": True},
              "boat": {"name": "Boat"},
          },
          "locations": {
              "river_town": {"name": "River Town"},
              "island": {"name": "Island"},
          },
          "paths": [
              {"from": "river_town", "to": "island", "requirements": {"transport": ["walk", "boat"]}, "steps": [{"type": "encounter", "biome": "river"}]},
          ],
      }

!travel Oakwood
---
"re:Run `!enc`[\\s\\S]*Encounter step has no biome"
---
name: route preview omits blank biome argument and warns when manual mode needs one
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000012"
  gvars:
    aaaa2002-2002-2002-2002-200000000012: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
          "exploration": {"config": {"enc_biome_source": "argument"}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
          },
          "paths": [
              {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": ""}]},
          ],
      }

!travel Oak track
---
re:Be more specific[\s\S]*Oakwood Forest[\s\S]*Oakwood East Trail
---
name: ambiguous destination asks for specificity
vars:
  svars:
    westmarch_config: "aaaa2003-2003-2003-2003-200000000003"
  gvars:
    aaaa2003-2003-2003-2003-200000000003: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
              "oakwood_east": {"name": "Oakwood East Trail"},
          },
          "paths": [],
      }

!travel Oakwood track
---
re:journey is now being tracked
---
name: route can be tracked
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000002"
  gvars:
    aaaa2002-2002-2002-2002-200000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
          },
          "paths": [
              {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]},
          ],
      }

!travel reset
---
re:Confirm with `!travel reset yes`
---
name: reset requires confirmation
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000002"
  gvars:
    aaaa2002-2002-2002-2002-200000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {"river_town": {"name": "River Town"}},
          "paths": [],
      }

!travel set Oakwood
---
re:Confirm with `!travel set "Oakwood Forest" yes`
---
name: set requires confirmation
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000002"
  gvars:
    aaaa2002-2002-2002-2002-200000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
          },
          "paths": [],
      }

!travel set Oakwood yes
---
re:Location set to[\s\S]*Oakwood Forest
---
name: set changes location when confirmed
vars:
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000002"
  gvars:
    aaaa2002-2002-2002-2002-200000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
          },
          "paths": [],
      }

!travel next
---
re:Arrived in[\s\S]*Oakwood Forest[\s\S]*Completed
---
name: next advances one-step journey to arrival
vars:
  cvars:
    wg_location: "river_town"
    wg_journey: '{"title":"River Town -> Oakwood Forest","from":"river_town","to":"oakwood","paths":[{"from":"river_town","to":"oakwood","steps":[{"type":"encounter","biome":"forest"}]}],"path_index":0,"step_index":0,"horse":false,"boat":false}'
  svars:
    westmarch_config: "aaaa2002-2002-2002-2002-200000000002"
  gvars:
    aaaa2002-2002-2002-2002-200000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"travel": True, "location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
          },
          "paths": [
              {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]},
          ],
      }

!travel next
---
're:Arrived in[\s\S]*Oakwood Forest[\s\S]*Time: Firstday, 1 Hammer 1492 DR 00:00[\s\S]*Weather: \*\*forest\*\*: Cool mist hangs beneath the trees\.'
---
name: next arrival can include configured time and weather
vars:
  cvars:
    wg_location: "river_town"
    wg_journey: '{"title":"River Town -> Oakwood Forest","from":"river_town","to":"oakwood","paths":[{"from":"river_town","to":"oakwood","steps":[{"type":"encounter","biome":"forest"}]}],"path_index":0,"step_index":0,"horse":false,"boat":false}'
  svars:
    westmarch_config: "aaaa2004-2004-2004-2004-200000000004"
  gvars:
    aaaa2004-2004-2004-2004-200000000004: |
      subsystems = {
          "travel": {
              "enabled": True,
              "commands": {"travel": True, "location": True, "time": True, "weather": True},
              "config": {"show_arrival_time": True, "show_arrival_weather": True},
          },
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town", "weather_area": "forest"},
              "oakwood": {"name": "Oakwood Forest", "weather_area": "forest"},
          },
          "paths": [
              {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]},
          ],
          "calendars": {
              "primary": {
                  "id": "primary",
                  "name": "Faerûnian Calendar",
                  "epoch_unix": 0,
                  "tick_rate": 0,
                  "seconds_per_day": 86400,
                  "start_year": 1492,
                  "months": [{"name": "Hammer", "days": 30}],
                  "weekdays": ["Firstday"],
                  "display_format": "{weekday}, {day} {month} {year} DR {hour}:{minute}",
              },
          },
          "weather": {
              "by_area": {
                  "forest": {"default": ["Cool mist hangs beneath the trees."]},
              },
          },
      }
