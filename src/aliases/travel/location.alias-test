!location
---
re:not configured
---
name: blocks without server config

!location
---
re:disabled on this server
---
name: rejects disabled location command
vars:
  svars:
    westmarch_config: "aaaa1000-1000-1000-1000-100000000000"
  gvars:
    aaaa1000-1000-1000-1000-100000000000: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"location": False}},
      }

!location help
---
re:Usage[\s\S]*location journey
---
name: shows help when enabled
vars:
  svars:
    westmarch_config: "aaaa1001-1001-1001-1001-100000000001"
  gvars:
    aaaa1001-1001-1001-1001-100000000001: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {"river_town": {"name": "River Town"}},
      }

!location
---
re:River Town[\s\S]*busy quay
---
name: shows config default location
vars:
  svars:
    westmarch_config: "aaaa1002-1002-1002-1002-100000000002"
  gvars:
    aaaa1002-1002-1002-1002-100000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town", "description": "A busy quay."},
              "oakwood": {"name": "Oakwood Forest"},
          },
      }

!location
---
re:River Town[\s\S]*Nearby[\s\S]*Oakwood Forest(?![\s\S]*Old Road)[\s\S]*Docks(?![\s\S]*Harbor lane)
---
name: shows concise nearby direct travel destinations
vars:
  svars:
    westmarch_config: "aaaa1003-1003-1003-1003-100000000003"
  gvars:
    aaaa1003-1003-1003-1003-100000000003: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "transport": {
              "walk": {"name": "Walking", "default": True},
              "horse": {"name": "Horse or mount"},
              "ship": {"name": "Ship"},
          },
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest", "description": "A nearby forest road."},
              "docks": {"name": "Docks", "description": "River landings and boats."},
          },
          "paths": [
              {"from": "river_town", "to": "oakwood", "label": "Old Road", "requirements": {"transport": ["walk", "horse"]}, "steps": [{"type": "encounter", "biome": "forest"}]},
              {"from": "river_town", "to": "docks", "label": "Harbor lane", "requirements": {"transport": "ship"}, "steps": [{"type": "proceed", "description": "Sail downriver."}]},
          ],
      }

!location
---
re:Activities
---
name: shows activities for current location
vars:
  svars:
    westmarch_config: "aaaa1004-1004-1004-1004-100000000004"
  gvars:
    aaaa1004-1004-1004-1004-100000000004: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town", "commands": {"enc": ["road"]}},
          },
      }

!location
---
're:Jobs[\s\S]*Caravan Guard[\s\S]*Shops[\s\S]*```text[\s\S]*General Store[\s\S]*Item[\s\S]*Buy[\s\S]*Sell[\s\S]*Rope, Hemp \(50 ft\)[\s\S]*2 gp[\s\S]*1 gp'
---
name: shows configured jobs and shop trade prices for current location
vars:
  svars:
    westmarch_config: "aaaa1005-1005-1005-1005-100000000005"
  gvars:
    aaaa1005-1005-1005-1005-100000000005: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"location": True}},
          "economy": {
              "enabled": True,
              "commands": {"job": True, "buy": True, "sell": True},
              "config": {
                  "jobs": [
                      {"id": "guard", "name": "Caravan Guard", "skills": ["athletics", "perception"]},
                  ],
              },
          },
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town", "commands": {"job": True, "buy": True, "sell": True}},
          },
      }
      shops = {
          "general": {
              "id": "general",
              "name": "General Store",
              "location_id": "river_town",
              "accepts_sells": True,
              "buyback": 0.5,
              "stock": [{"item": "Rope, Hemp (50 ft)", "price": {"gold": 2}}],
          },
      }

!location
---
re:Oakwood Forest
---
name: shows character cvar location over default
vars:
  cvars:
    wg_location: "oakwood"
  svars:
    westmarch_config: "aaaa1002-1002-1002-1002-100000000002"
  gvars:
    aaaa1002-1002-1002-1002-100000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
          },
      }

!location journey
---
re:Oakwood Forest[\s\S]*River Town[\s\S]*!enc forest
---
name: can include active journey summary
vars:
  cvars:
    wg_location: "river_town"
    wg_journey: '{"title":"River Town -> Oakwood Forest","from":"river_town","to":"oakwood","paths":[{"from":"river_town","to":"oakwood","steps":[{"type":"encounter","biome":"forest"}]}],"path_index":0,"step_index":0,"horse":false,"boat":false}'
  svars:
    westmarch_config: "aaaa1002-1002-1002-1002-100000000002"
  gvars:
    aaaa1002-1002-1002-1002-100000000002: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"location": True}},
      }
      world_data = {
          "default_location": "river_town",
          "locations": {
              "river_town": {"name": "River Town"},
              "oakwood": {"name": "Oakwood Forest"},
          },
      }
