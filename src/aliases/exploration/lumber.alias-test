!lumber forest
---
re:cooldown|wait|seconds
---
name: "cooldown blocks repeat use"
vars:
  cvars:
    wg_stats: '{"lumber": {"last_used_at": 9999999999}}'
  svars:
    westmarch_config: "eeee3333-3333-3333-3333-333333333333"
  gvars:
    eeee3333-3333-3333-3333-333333333333: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"lumber": True},
              "config": {
                  "enc_biome_source": "argument",
                  "distribution": {"combat": 0, "quest": 0, "gather": 100},
              },
              "command_config": {"lumber": {"cooldown_seconds": 120}},
          },
      }
      policies = {"exploration": {"enforce_cooldowns": True}}
      world_data = {
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["lumber.gather"], "flavour", "Fallen oak", "", "gather"]]

!lumber
---
re:Fallen oak
---
name: "location mode infers biome from character location"
vars:
  svars:
    westmarch_config: "eeee3334-3334-3334-3334-333333333334"
  gvars:
    eeee3334-3334-3334-3334-333333333334: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"lumber": True},
              "config": {
                  "enc_biome_source": "location",
                  "distribution": {"combat": 0, "quest": 0, "gather": 100},
              },
          },
          "travel": {
              "enabled": True,
              "commands": {"location": True},
          },
      }
      world_data = {
          "default_location": "oakwood",
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
          "locations": {
              "oakwood": {
                  "name": "Oakwood",
                  "commands": {"lumber": ["forest"]},
              },
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["lumber.gather"], "flavour", "Fallen oak", "", "gather"]]
  character:
    cvars:
      wg_location: "oakwood"

!lumber
---
re:No encounters configured for \*\*Oakwood\*\* / \*\*forest\*\* / \*\*lumber\*\*
---
name: "inferred biome missing pool includes location"
vars:
  svars:
    westmarch_config: "eeee3334-3334-3334-3334-333333333736"
  gvars:
    eeee3334-3334-3334-3334-333333333736: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"lumber": True},
              "config": {"enc_biome_source": "location"},
          },
          "travel": {"enabled": True, "commands": {"location": True}},
      }
      world_data = {
          "default_location": "oakwood",
          "biomes": {"forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555736"}},
          "locations": {"oakwood": {"name": "Oakwood", "commands": {"lumber": ["forest"]}}},
      }
    eeee5555-5555-5555-5555-555555555736: |
      []
