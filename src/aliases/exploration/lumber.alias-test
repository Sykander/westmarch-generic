!lumber
---
re:not configured
---
name: blocks without server config

!lumber
---
title: Lumber
---
name: passes auth when exploration lumber enabled
vars:
  svars:
    westmarch_config: "eeee1111-1111-1111-1111-111111111111"
  gvars:
    eeee1111-1111-1111-1111-111111111111: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"lumber": True},
          },
      }

!lumber
---
re:disabled on this server
---
name: rejects disabled lumber command
vars:
  svars:
    westmarch_config: "eeee2222-2222-2222-2222-222222222222"
  gvars:
    eeee2222-2222-2222-2222-222222222222: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"lumber": False},
          },
      }

!lumber help
---
title: Lumber
---
name: help stub when lumber enabled
vars:
  svars:
    westmarch_config: "eeee1111-1111-1111-1111-111111111111"
  gvars:
    eeee1111-1111-1111-1111-111111111111: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"lumber": True},
          },
      }

!lumber forest
---
re:Fallen oak
---
name: "manual biome rolls lumber encounter from pool"
vars:
  svars:
    westmarch_config: "eeee3333-3333-3333-3333-333333333333"
  gvars:
    eeee3333-3333-3333-3333-333333333333: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"lumber": True},
              "config": {
                  "enc_biome_source": "argument",
                  "distribution": {"combat": 0, "quest": 0, "gather": 100},
              },
          },
      }
      world_data = {
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["lumber.gather"], "flavour", "Fallen oak", "Good timber.", "gather"]]

!lumber
