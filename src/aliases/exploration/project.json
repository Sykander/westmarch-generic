{
  "name": "avrae-aliases-exploration",
  "projectType": "application",
  "sourceRoot": "src/aliases/exploration",
  "tags": ["scope:avrae", "type:aliases"],
  "implicitDependencies": [
    "avrae-sourcemaps",
    "avrae-gvar-configs",
    "avrae-gvar-utils-core",
