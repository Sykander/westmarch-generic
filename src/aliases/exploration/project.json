    "test": {
      "executor": "nx:noop",
      "cache": true,
      "dependsOn": [
        "test-enc",
        "test-fish",
        "test-forage",
        "test-hunt",
        "test-loot",
        "test-lumber",
        "test-mine"
      ],
      "outputs": []
    },
    "test-enc": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": [
        "avraeAliasBase",
        "{workspaceRoot}/src/gvars/utils/catalogues/**/*",
        "{workspaceRoot}/src/gvars/utils/encounters/**/*",
        "{workspaceRoot}/src/gvars/utils/exploration/**/*",
        "{workspaceRoot}/src/gvars/utils/pc/**/*",
        "{workspaceRoot}/src/gvars/utils/world/**/*"
      ],
      "outputs": [],
      "options": {
        "command": "avrae-ls --log-level INFO --run-tests src/aliases/exploration/enc.alias-test"
      }
    },
