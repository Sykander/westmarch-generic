!loot Wolf
---
re:Started loot table session|nothing to loot
---
name: "start loot session for creature"
vars:
  uvars:
    _wm_command: loot
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"loot": True},
          },
      }

!loot Custom
---
re:Be more specific|Custom Beast|Custom Drake
---
name: loot reports ambiguous creature matches
vars:
  uvars:
    _wm_command: loot
  svars:
    westmarch_config: "eeee7778-7778-7778-7778-777777777778"
  gvars:
    eeee7778-7778-7778-7778-777777777778: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"loot": True},
          },
      }
      world_data = {
          "monsters": [
              {"name": "Custom Beast", "cr": 1, "type_str": "Beast"},
              {"name": "Custom Drake", "cr": 2, "type_str": "Dragon"},
          ],
      }

!loot clear
---
re:cleared|no active|session
---
name: "clear ends loot session"
vars:
  uvars:
    _wm_command: loot
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"loot": True},
          },
      }

!loot
---
re:Wolf
---
name: "bare loot shows active session status"
vars:
  uvars:
    _wm_command: loot
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  cvars:
    wg_loot_session: '{"creature": "Wolf", "items": []}'
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"loot": True},
          },
      }

!loot Wolf
---
re:Be more specific|Wolf Trophy|Wolf Ration
---
name: loot asks for specificity when active loot query matches multiple items
vars:
  uvars:
    _wm_command: loot
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  cvars:
    wg_loot_session: '{"creature": "Wolf", "items": [{"id": "trophy", "name": "Wolf Trophy [CR 0.25]", "skill": "nature", "dc": 10, "kind": "item", "amount": 1}, {"id": "ration", "name": "Wolf Ration", "skill": "survival", "dc": 10, "kind": "item", "amount": 1}]}'
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"loot": True},
          },
      }

!loot ration
---
re:Recovered \*\*Wolf Ration\*\*[\s\S]*Loot cleared
---
name: loot item attempt can recover and clear final lootable
vars:
  uvars:
    _wm_command: loot
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  cvars:
    wg_loot_session: '{"creature": "Wolf", "items": [{"id": "ration", "name": "Wolf Ration", "skill": "survival", "dc": 0, "kind": "item", "amount": 1, "bag": "Rations"}]}'
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"loot": True},
          },
      }

!loot Image Beast
---
re:-image https://example.test/image-beast.png
---
name: loot start can show monster art as embed image
vars:
  uvars:
    _wm_command: loot
  svars:
    westmarch_config: "eeee8888-8888-8888-8888-888888888888"
  gvars:
    eeee8888-8888-8888-8888-888888888888: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"loot": True},
              "config": {
                  "monster_images": {"loot": "image"},
              },
          },
      }
      world_data = {
          "monsters": [
              {
                  "name": "Image Beast",
                  "cr": 1,
                  "type_str": "Beast",
                  "image_url": "https://example.test/image-beast.png",
              },
          ],
      }

!loot
---
re:Quiet Beast|Nature check
---
name: loot can hide public check dcs
vars:
  uvars:
    _wm_command: loot
  svars:
    westmarch_config: "eeee8989-8989-8989-8989-898989898989"
  cvars:
    wg_loot_session: '{"creature": "Quiet Beast", "items": [{"id": "trophy", "name": "Quiet Beast Trophy [CR 1]", "skill": "nature", "dc": 12, "kind": "item", "amount": 1}]}'
  gvars:
    eeee8989-8989-8989-8989-898989898989: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"loot": True},
              "config": {
                  "show_check_dcs": {"loot": False},
              },
          },
      }
      world_data = {
          "monsters": [
              {
                  "name": "Quiet Beast",
                  "cr": 1,
                  "type_str": "Beast",
              },
          ],
      }
