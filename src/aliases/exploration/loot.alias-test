!loot
---
re:Wolf
---
name: "planned: bare loot shows active session status"
vars:
  uvars:
    _wm_command: loot
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  cvars:
    wg_loot_session: '{"creature": "Wolf", "items": []}'
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"loot": True},
          },
      }
