          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555", "name": "Forest"},
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["forage.gather"], "flavour", "Wild mushrooms", "", "gather"]]

!forage forest
---
re:cooldown|wait|seconds
---
name: "cooldown blocks repeat use"
vars:
  uvars:
    _wm_command: forage
  cvars:
    wg_stats: '{"forage": {"last_used_at": 9999999999}}'
  svars:
    westmarch_config: "eeee3333-3333-3333-3333-333333333333"
  gvars:
    eeee3333-3333-3333-3333-333333333333: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"forage": True},
              "config": {
                  "enc_biome_source": "argument",
                  "distribution": {"combat": 0, "quest": 0, "gather": 100},
              },
              "command_config": {"forage": {"cooldown_seconds": 120}},
          },
      }
      policies = {"exploration": {"enforce_cooldowns": True}}
      world_data = {
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["forage.gather"], "flavour", "Wild mushrooms", "", "gather"]]

!forage
---
re:Wild mushrooms
---
name: "location mode infers biome from character location"
vars:
  uvars:
    _wm_command: forage
  svars:
    westmarch_config: "eeee3334-3334-3334-3334-333333333334"
  gvars:
    eeee3334-3334-3334-3334-333333333334: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"forage": True},
              "config": {
                  "enc_biome_source": "location",
                  "distribution": {"combat": 0, "quest": 0, "gather": 100},
              },
          },
          "travel": {
              "enabled": True,
              "commands": {"location": True},
          },
      }
      world_data = {
          "default_location": "oakwood",
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
          "locations": {
              "oakwood": {
                  "name": "Oakwood",
                  "commands": {"forage": ["forest"]},
              },
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["forage.gather"], "flavour", "Wild mushrooms", "", "gather"]]
  character:
    cvars:
      wg_location: "oakwood"

!forage forest
---
re:Wild mushrooms[\s\S]*Arrived in[\s\S]*Oakwood Forest[\s\S]*Completed
---
name: activity-specific journey step completes after successful forage
vars:
  uvars:
    _wm_command: forage
  cvars:
    wg_location: "river_town"
    wg_journey: '{"title":"River Town -> Oakwood Forest","from":"river_town","to":"oakwood","paths":[{"from":"river_town","to":"oakwood","steps":[{"type":"encounter","activity":"forage","biome":"forest"}]}],"path_index":0,"step_index":0,"horse":false,"boat":false}'
  svars:
    westmarch_config: "eeee3335-3335-3335-3335-333333333335"
  gvars:
    eeee3335-3335-3335-3335-333333333335: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"forage": True},
              "config": {
                  "enc_biome_source": "argument",
                  "distribution": {"combat": 0, "quest": 0, "gather": 100},
              },
          },
          "travel": {
              "enabled": True,
              "commands": {"travel": True, "location": True},
          },
      }
      policies = {"exploration": {"enforce_cooldowns": False}}
      world_data = {
          "default_location": "river_town",
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
          "locations": {
              "river_town": {"name": "River Town", "commands": {"forage": ["road"]}},
              "oakwood": {"name": "Oakwood Forest", "commands": {"forage": ["forest"]}},
          },
          "paths": [
              {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "activity": "forage", "biome": "forest"}]},
          ],
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["forage.gather"], "flavour", "Wild mushrooms", "", "gather"]]
