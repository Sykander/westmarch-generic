!forage
---
re:not configured
---
name: blocks without server config
vars:
  uvars:
    _wm_command: forage

!forage
---
title: Forage
---
name: passes auth when exploration forage enabled
vars:
  uvars:
    _wm_command: forage
  svars:
    westmarch_config: "eeee1111-1111-1111-1111-111111111111"
  gvars:
    eeee1111-1111-1111-1111-111111111111: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"forage": True},
          },
      }

!forage
---
re:disabled on this server
---
name: rejects disabled forage command
vars:
  uvars:
    _wm_command: forage
  svars:
    westmarch_config: "eeee2222-2222-2222-2222-222222222222"
  gvars:
    eeee2222-2222-2222-2222-222222222222: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"forage": False},
          },
      }

!forage help
---
title: Forage
---
name: help stub when forage enabled
vars:
  uvars:
    _wm_command: forage
  svars:
    westmarch_config: "eeee1111-1111-1111-1111-111111111111"
  gvars:
    eeee1111-1111-1111-1111-111111111111: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"forage": True},
          },
      }

!forage forest
---
re:Wild mushrooms
---
name: "manual biome rolls forage encounter from pool"
vars:
  uvars:
    _wm_command: forage
  svars:
    westmarch_config: "eeee3333-3333-3333-3333-333333333333"
  gvars:
    eeee3333-3333-3333-3333-333333333333: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"forage": True},
              "config": {
                  "enc_biome_source": "argument",
                  "distribution": {"combat": 0, "quest": 0, "gather": 100},
              },
          },
      }
      world_data = {
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["forage.gather"], "flavour", "Wild mushrooms", "Fungi on rotting logs.", "gather"]]

!forage
---
re:biome
---
name: "argument mode requires biome code"
vars:
  uvars:
    _wm_command: forage
  svars:
    westmarch_config: "eeee3333-3333-3333-3333-333333333333"
  gvars:
    eeee3333-3333-3333-3333-333333333333: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"forage": True},
              "config": {"enc_biome_source": "argument"},
          },
      }
      world_data = {
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["forage.gather"], "flavour", "Wild mushrooms", "", "gather"]]

