!enc forest
---
re:cooldown|wait|seconds
---
name: "planned: cooldown blocks repeat use"
vars:
  uvars:
    _wm_command: enc
  svars:
    westmarch_config: "eeee3333-3333-3333-3333-333333333333"
  gvars:
    eeee3333-3333-3333-3333-333333333333: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"enc": True},
              "config": {
                  "enc_biome_source": "argument",
                  "distribution": {"combat": 0, "quest": 0, "gather": 100},
              },
              "command_config": {"enc": {"cooldown_seconds": 120}},
          },
      }
      policies = {"exploration": {"enforce_cooldowns": True}}
      world_data = {
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      pools = {
          "enc": {
              "gather": [{"kind": "gather", "name": "Berries in the Wild"}],
          },
      }
  character:
    cvars:
      wg_stats:
        enc:
          last_used_at: 9999999999

