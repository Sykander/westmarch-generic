!hunt Custom
---
re:Be more specific|Custom Beast|Custom Drake
---
name: hunt reports ambiguous creature matches
vars:
  svars:
    westmarch_config: "eeee7778-7778-7778-7778-777777777778"
  gvars:
    eeee7778-7778-7778-7778-777777777778: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
          },
      }
      world_data = {
          "monsters": [
              {"name": "Custom Beast", "cr": 1, "type_str": "Beast"},
              {"name": "Custom Drake", "cr": 2, "type_str": "Dragon"},
          ],
      }

!hunt Wolf -p 3
---
re:Group hunt[\s\S]*party size \*\*3\*\*[\s\S]*-p 3
---
name: "group hunt uses named party-size flag"
vars:
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
          },
      }

!hunt Wolf -p 3 -n 2 -b 5[previous]
---
re:Wolf[\s\S]*Group hunt[\s\S]*-p 3[\s\S]*-n 3
---
name: group hunt flags do not affect creature lookup
vars:
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
          },
      }

!hunt Wolf 3
---
re:Found no monster matches
---
