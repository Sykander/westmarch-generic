!hunt Custom
---
re:Be more specific|Custom Beast|Custom Drake
---
name: hunt reports ambiguous creature matches
vars:
  uvars:
    _wm_command: hunt
  svars:
    westmarch_config: "eeee7778-7778-7778-7778-777777777778"
  gvars:
    eeee7778-7778-7778-7778-777777777778: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
          },
      }
      world_data = {
          "monsters": [
              {"name": "Custom Beast", "cr": 1, "type_str": "Beast"},
              {"name": "Custom Drake", "cr": 2, "type_str": "Dragon"},
          ],
      }

!hunt Wolf 3
---
re:group|party|next hunter
---
name: "group hunt failure offers chained command"
vars:
  uvars:
    _wm_command: hunt
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
          },
      }

!hunt Wolf 3 -n 2 -b 5[previous]
---
re:Wolf[\s\S]*Group hunt[\s\S]*-n 3
---
name: group hunt flags do not affect creature lookup
vars:
  uvars:
    _wm_command: hunt
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
          },
      }

!hunt Image Beast
---
re:-image https://example.test/image-beast.png
---
name: hunt success can show monster art as embed image
vars:
  uvars:
    _wm_command: hunt
  svars:
    westmarch_config: "eeee8888-8888-8888-8888-888888888888"
  gvars:
    eeee8888-8888-8888-8888-888888888888: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
              "config": {
                  "monster_images": {"hunt": "image"},
              },
          },
      }
      world_data = {
          "monsters": [
              {
                  "name": "Image Beast",
                  "cr": -9,
                  "type_str": "Beast",
                  "image_url": "https://example.test/image-beast.png",
              },
          ],
      }

!hunt Image Beast
---
"re:Survival check:"
---
name: hunt can hide public check dc
vars:
  uvars:
    _wm_command: hunt
  svars:
    westmarch_config: "eeee8989-8989-8989-8989-898989898989"
  gvars:
    eeee8989-8989-8989-8989-898989898989: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
              "config": {
                  "show_check_dcs": {"hunt": False},
              },
          },
      }
      world_data = {
          "monsters": [
              {
                  "name": "Image Beast",
                  "cr": -9,
                  "type_str": "Beast",
                  "image_url": "https://example.test/image-beast.png",
              },
          ],
      }
