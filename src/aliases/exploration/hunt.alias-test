!hunt
---
re:not configured
---
name: blocks without server config

!hunt
---
re:Provide a \*\*creature\*\*[\s\S]*!hunt help
---
name: asks for creature when hunt enabled without args
vars:
  svars:
    westmarch_config: "eeee1111-1111-1111-1111-111111111111"
  gvars:
    eeee1111-1111-1111-1111-111111111111: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
          },
      }

!hunt
---
re:disabled on this server
---
name: rejects disabled hunt command
vars:
  svars:
    westmarch_config: "eeee2222-2222-2222-2222-222222222222"
  gvars:
    eeee2222-2222-2222-2222-222222222222: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": False},
          },
      }

!hunt help
---
title: Hunt
---
name: help stub when hunt enabled
vars:
  svars:
    westmarch_config: "eeee1111-1111-1111-1111-111111111111"
  gvars:
    eeee1111-1111-1111-1111-111111111111: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
          },
      }

!hunt help
---
re:creature[\s\S]*-p party_size[\s\S]*enc
---
name: "help documents hunt usage and enc prerequisite"
vars:
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True, "enc": True},
          },
      }

!hunt Wolf
---
re:Survival|DC
---
name: "hunt runs survival check for known creature"
vars:
  svars:
    westmarch_config: "eeee7777-7777-7777-7777-777777777777"
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
          },
      }

!hunt Wolf
---
re:Survival|DC
---
name: "hunt runs at location with hunt list"
vars:
  svars:
    westmarch_config: "eeee7710-7710-7710-7710-777777777710"
  gvars:
    eeee7710-7710-7710-7710-777777777710: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
              "config": {"hunt_location_policy": "location"},
          },
          "travel": {
              "enabled": True,
              "commands": {"location": True},
          },
      }
      world_data = {
          "default_location": "forest_camp",
          "locations": {
              "forest_camp": {"name": "Forest Camp", "commands": {"hunt": ["forest"]}},
          },
      }

!hunt Wolf
---
re:not available at \*\*Waterdeep\*\*
---
name: "hunt rejects location without hunt list"
vars:
  svars:
    westmarch_config: "eeee7711-7711-7711-7711-777777777711"
  gvars:
    eeee7711-7711-7711-7711-777777777711: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
              "config": {"hunt_location_policy": "location"},
          },
          "travel": {
              "enabled": True,
              "commands": {"location": True},
          },
      }
      world_data = {
          "default_location": "waterdeep",
          "locations": {
              "waterdeep": {"name": "Waterdeep", "commands": {"enc": ["urban"]}},
          },
      }

!hunt Wolf
---
re:Survival|DC
---
name: "hunt monsters policy allows listed local creature"
vars:
  svars:
    westmarch_config: "eeee7712-7712-7712-7712-777777777712"
  gvars:
    eeee7712-7712-7712-7712-777777777712: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"hunt": True},
              "config": {"hunt_location_policy": "monsters"},
          },
          "travel": {
              "enabled": True,
              "commands": {"location": True},
          },
      }
      world_data = {
          "default_location": "forest_camp",
          "locations": {
              "forest_camp": {
                  "name": "Forest Camp",
                  "commands": {"hunt": ["forest"]},
                  "huntable_monsters": ["Wolf"],
              },
          },
      }

!hunt Goblin
---
re:Goblin[\s\S]*not listed as huntable at \*\*Forest Camp\*\*
