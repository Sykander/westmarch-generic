!show
---
re:No config loaded
---
name: unwired shows missing config message
vars:
  uvars:
    _wm_command: show

!show
---
re:My Demo Realm
---
name: wired config shows world name
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff3333-3333-3333-3333-333333333333"
  gvars:
    ffff3333-3333-3333-3333-333333333333: |
      display = {"name": "My Demo Realm"}

!show
---
"re:```diff[\\s\\S]*exploration: off"
---
name: show lists subsystem status
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff3333-3333-3333-3333-333333333333"
  gvars:
    ffff3333-3333-3333-3333-333333333333: |
      display = {"name": "My Demo Realm"}

!show
---
re:Data overview
---
name: show includes data overview section
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!show wiring
---
re:ffff1111-1111-1111-1111-111111111111|dashboard/gvars\?lookup=ffff1111-1111-1111-1111-111111111111
---
name: show section filter wiring includes full gvar id and dashboard link
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!show
---
"re:\\+ exploration: on|- exploration: error"
---
name: show marks enabled subsystem in diff block
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff4444-4444-4444-4444-444444444444"
  gvars:
    ffff4444-4444-4444-4444-444444444444: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"enc": False},
          },
      }

!show
---
"re:- exploration: error"
---
name: show marks invalid enabled subsystem red in diff block
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff5555-5555-5555-5555-555555555555"
  gvars:
    ffff5555-5555-5555-5555-555555555555: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"enc": True},
          },
      }

!show not_a_section
---
re:Unknown section
---
name: show rejects unknown section
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body
