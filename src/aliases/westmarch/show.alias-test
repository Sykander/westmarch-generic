!show player_setup
---
"re:```ansi[\\s\\S]*checks[\\s\\S]*1[\\s\\S]*hud.fields"
---
name: show section filter player setup summarizes configured checks
vars:
  svars:
    westmarch_config: "ffff7777-7777-7777-7777-777777777777"
  gvars:
    ffff7777-7777-7777-7777-777777777777: |
      policies = {
          "player_setup": {
              "checks": [
                  {"type": "cvar", "key": "vsheet", "label": "vSheet"},
              ],
          },
      }

!show display
---
"re:```ansi[\\s\\S]*command_thumbnail[\\s\\S]*character[\\s\\S]*error_embeds.auto_delete[\\s\\S]*true[\\s\\S]*error_embeds.timeout_seconds[\\s\\S]*60"
---
name: show section filter display summarizes command thumbnail and error policy
vars:
  svars:
    westmarch_config: "ffff8888-8888-8888-8888-888888888888"
  gvars:
    ffff8888-8888-8888-8888-888888888888: |
      policies = {
          "display": {"command_thumbnail": "character"},
      }

!show policies
---
"re:display.error_embeds.auto_delete[\\s\\S]*false[\\s\\S]*display.error_embeds.timeout_seconds[\\s\\S]*5"
---
name: show policies summarizes custom error embed policy
vars:
  svars:
    westmarch_config: "ffff8989-8989-8989-8989-898989898989"
  gvars:
    ffff8989-8989-8989-8989-898989898989: |
      policies = {
          "display": {"error_embeds": {"auto_delete": False, "timeout_seconds": 5}},
      }

!show crafting
---
"re:```ansi[\\s\\S]*rules_version[\\s\\S]*2024[\\s\\S]*recipe_mode[\\s\\S]*mixed[\\s\\S]*require_known_spell[\\s\\S]*true[\\s\\S]*spells[\\s\\S]*engine:catalogues/spells[\\s\\S]*scrolls_bag[\\s\\S]*Scroll Satchel"
---
name: show section filter crafting summarizes catalogues and item output
vars:
  svars:
    westmarch_config: "ffff9999-9999-9999-9999-999999999999"
  gvars:
    ffff9999-9999-9999-9999-999999999999: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"scribe": True},
              "config": {
                  "rules_version": "2024",
                  "catalogues": {"spells": "engine:catalogues/spells"},
                  "item_handling": {"mode": "bags", "scrolls_bag": "Scroll Satchel"},
              },
          },
      }

!show policies
---
"re:```ansi[\\s\\S]*travel.consume_rations[\\s\\S]*true[\\s\\S]*economy.enforce_wallet_caps[\\s\\S]*true"
---
name: show section filter policies summarizes remaining policy fields
vars:
  svars:
    westmarch_config: "ffffaaaa-aaaa-aaaa-aaaa-ffffffffaaaa"
  gvars:
    ffffaaaa-aaaa-aaaa-aaaa-ffffffffaaaa: |
      policies = {
          "travel": {"consume_rations": True},
          "economy": {"enforce_wallet_caps": True},
      }

!show -page policies
---
"re:```ansi[\\s\\S]*travel.consume_rations[\\s\\S]*true[\\s\\S]*economy.enforce_wallet_caps[\\s\\S]*true"
---
name: show page flag selects a section
vars:
  svars:
    westmarch_config: "ffffabab-abab-abab-abab-ffffffffabab"
  gvars:
    ffffabab-abab-abab-abab-ffffffffabab: |
      policies = {
          "travel": {"consume_rations": True},
          "economy": {"enforce_wallet_caps": True},
      }
