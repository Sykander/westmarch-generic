!show wiring
---
"re:ffff1111-1111-1111-1111-111111111111[\\s\\S]*\\[Westmarch config editor\\]\\(https://sykander.github.io/westmarch-generic/\\?westmarch_config=ffff1111-1111-1111-1111-111111111111\\)[\\s\\S]*\\[Avrae gvar dashboard\\]\\(https://avrae.io/dashboard/gvars\\?lookup=ffff1111-1111-1111-1111-111111111111\\)"
---
name: show section filter wiring includes full gvar id and named links
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!show runtime
---
"re:```yaml[\\s\\S]*rules_edition: 2014"
---
name: show section filter runtime uses yaml style
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!show
---
"re:exploration:[\\s\\S]*enabled: true[\\s\\S]*enc: true[\\s\\S]*forage: false"
---
name: show marks enabled subsystem in yaml block
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff4444-4444-4444-4444-444444444444"
  gvars:
    ffff4444-4444-4444-4444-444444444444: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"enc": True, "forage": False},
          },
      }
      world_data = {
          "biomes": {"forest": {"gvar_id": "ffff6666-6666-6666-6666-666666666666"}},
      }
    ffff6666-6666-6666-6666-666666666666: |
      [
        [["enc.combat"], "combat", "Wolf", "", 1],
        [["enc.quest"], "quest", "Tracks", ""],
        [["enc.gather"], "flavour", "Herbs", "", "gather"]
      ]

!show
---
"re:exploration:[\\s\\S]*enabled: true[\\s\\S]*enc: true"
---
name: show does not validate enabled subsystem data
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff5555-5555-5555-5555-555555555555"
  gvars:
    ffff5555-5555-5555-5555-555555555555: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"enc": True},
          },
      }

!show not_a_section
---
re:Unknown section
---
name: show rejects unknown section
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!show player_setup
---
"re:```yaml[\\s\\S]*checks: 1[\\s\\S]*hud.fields"
---
name: show section filter player setup summarizes configured checks
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff7777-7777-7777-7777-777777777777"
  gvars:
    ffff7777-7777-7777-7777-777777777777: |
      policies = {
          "player_setup": {
              "checks": [
                  {"type": "cvar", "key": "vsheet", "label": "vSheet"},
              ],
          },
      }

!show display
---
"re:```yaml[\\s\\S]*command_thumbnail: character"
---
name: show section filter display summarizes command thumbnail policy
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff8888-8888-8888-8888-888888888888"
  gvars:
    ffff8888-8888-8888-8888-888888888888: |
      policies = {
          "display": {"command_thumbnail": "character"},
      }
