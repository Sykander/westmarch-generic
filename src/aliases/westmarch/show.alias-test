!show
---
re:No config loaded
---
name: unwired shows missing config message

!show
---
"re:My Demo Realm[\\s\\S]*subsystems_enabled[\\s\\S]*Details"
---
name: wired config shows compact status card
vars:
  svars:
    westmarch_config: "ffff3333-3333-3333-3333-333333333333"
  gvars:
    ffff3333-3333-3333-3333-333333333333: |
      display = {"name": "My Demo Realm"}

!show subsystems
---
"re:```ansi[\\s\\S]*exploration:[\\s\\S]*enabled[\\s\\S]*false[\\s\\S]*enc[\\s\\S]*false[\\s\\S]*forage[\\s\\S]*false"
---
name: show subsystem section lists subsystem status
vars:
  svars:
    westmarch_config: "ffff3333-3333-3333-3333-333333333333"
  gvars:
    ffff3333-3333-3333-3333-333333333333: |
      display = {"name": "My Demo Realm"}

!show subsystems
---
"re:travel:[\\s\\S]*route_priority[\\s\\S]*least_encs[\\s\\S]*show_arrival_time[\\s\\S]*true[\\s\\S]*show_arrival_weather[\\s\\S]*true[\\s\\S]*combat_add_prompt[\\s\\S]*madd_commands[\\s\\S]*economy:[\\s\\S]*job_location_policy[\\s\\S]*warn[\\s\\S]*ask_to_confirm_purchases[\\s\\S]*true[\\s\\S]*jobs[\\s\\S]*1"
---
name: show subsystem section lists travel arrival and economy job config
vars:
  svars:
    westmarch_config: "ffff3434-3434-3434-3434-343434343434"
  gvars:
    ffff3434-3434-3434-3434-343434343434: |
      subsystems = {
          "travel": {
              "enabled": True,
              "commands": {"travel": True, "location": True, "time": True, "weather": True},
              "config": {"route_priority": "least_encs", "show_arrival_time": True, "show_arrival_weather": True, "combat_add_prompt": "madd_commands"},
          },
          "economy": {
              "enabled": True,
              "commands": {"job": True},
              "config": {
                  "job_location_policy": "warn",
                  "ask_to_confirm_purchases": True,
                  "jobs": [{"id": "guard", "name": "Caravan Guard"}],
              },
          },
      }

!show
---
"re:Details[\\s\\S]*westmarch show data"
---
name: bare show points to detailed data section
vars:
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!show data
---
"re:```ansi[\\s\\S]*locations[\\s\\S]*1[\\s\\S]*paths[\\s\\S]*0[\\s\\S]*transport[\\s\\S]*2"
---
name: show data includes transport count
vars:
  svars:
    westmarch_config: "ffff1212-1212-1212-1212-121212121212"
  gvars:
    ffff1212-1212-1212-1212-121212121212: |
      world_data = {
          "locations": {"river_town": {"name": "River Town"}},
          "paths": [],
          "transport": {
              "walk": {"name": "Walking", "default": True, "aliases": ["walking"]},
              "horse": {"name": "Horse or mount", "aliases": ["riding_horse"]},
          },
      }

!show data
---
"re:```ansi[\\s\\S]*locations[\\s\\S]*2[\\s\\S]*paths[\\s\\S]*1[\\s\\S]*locations_gvar_id[\\s\\S]*ffff2424[\\s\\S]*paths_gvar_id[\\s\\S]*ffff2525"
---
name: show data counts external location and path gvars
vars:
  svars:
    westmarch_config: "ffff2323-2323-2323-2323-232323232323"
  gvars:
    ffff2323-2323-2323-2323-232323232323: |
      world_data = {
          "locations_gvar_id": "ffff2424-2424-2424-2424-242424242424",
          "paths_gvar_id": "ffff2525-2525-2525-2525-252525252525",
      }
    ffff2424-2424-2424-2424-242424242424: |
      {"river_town":{"name":"River Town"},"oakwood":{"name":"Oakwood Forest"}}
    ffff2525-2525-2525-2525-252525252525: |
      {"paths_by_from":{"river_town":[{"from":"river_town","to":"oakwood","steps":[{"type":"proceed","description":"Follow the road."}]}]}}

!show wiring
---
"re:ffff1111-1111-1111-1111-111111111111[\\s\\S]*\\[Westmarch config editor\\]\\(https://sykander.github.io/westmarch-generic/\\?westmarch_config=ffff1111-1111-1111-1111-111111111111\\)[\\s\\S]*\\[Avrae gvar dashboard\\]\\(https://avrae.io/dashboard/gvars\\?lookup=ffff1111-1111-1111-1111-111111111111\\)"
---
