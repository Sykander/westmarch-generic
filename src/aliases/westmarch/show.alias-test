!show
---
re:No config loaded
---
name: unwired shows missing config message
vars:
  uvars:
    _wm_command: show

!show
---
re:My Demo Realm
---
name: wired config shows world name
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff3333-3333-3333-3333-333333333333"
  gvars:
    ffff3333-3333-3333-3333-333333333333: |
      display = {"name": "My Demo Realm"}

!show
---
"re:```diff[\\s\\S]*exploration: off[\\s\\S]*enc: off[\\s\\S]*forage: off"
---
name: show lists subsystem status
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff3333-3333-3333-3333-333333333333"
  gvars:
    ffff3333-3333-3333-3333-333333333333: |
      display = {"name": "My Demo Realm"}

!show
---
re:Data overview
---
name: show includes data overview section
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!show wiring
---
"re:ffff1111-1111-1111-1111-111111111111[\\s\\S]*\\[Westmarch config editor\\]\\(https://sykander.github.io/westmarch-generic/\\?westmarch_config=ffff1111-1111-1111-1111-111111111111\\)[\\s\\S]*\\[Avrae gvar dashboard\\]\\(https://avrae.io/dashboard/gvars\\?lookup=ffff1111-1111-1111-1111-111111111111\\)"
---
name: show section filter wiring includes full gvar id and named links
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!show
---
"re:\\+ exploration: on[\\s\\S]*\\+   enc: on[\\s\\S]*forage: off"
---
name: show marks enabled subsystem in diff block
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff4444-4444-4444-4444-444444444444"
  gvars:
    ffff4444-4444-4444-4444-444444444444: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"enc": True, "forage": False},
          },
      }
      world_data = {
          "biomes": {"forest": {"gvar_id": "ffff6666-6666-6666-6666-666666666666"}},
      }
    ffff6666-6666-6666-6666-666666666666: |
      [
        [["enc.combat"], "combat", "Wolf", "", 1],
        [["enc.quest"], "quest", "Tracks", ""],
        [["enc.gather"], "flavour", "Herbs", "", "gather"]
      ]

!show
---
"re:- exploration: error[\\s\\S]*-   enc: error"
---
name: show marks invalid enabled subsystem red in diff block
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff5555-5555-5555-5555-555555555555"
  gvars:
    ffff5555-5555-5555-5555-555555555555: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"enc": True},
          },
      }

!show not_a_section
---
re:Unknown section
---
name: show rejects unknown section
vars:
  uvars:
    _wm_command: show
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body
