!show runtime
---
"re:```ansi[\\s\\S]*rules_edition[\\s\\S]*2024"
---
name: show section filter runtime reads server 2024 profile
profile: server2024
vars:
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!show subsystems
---
"re:exploration:[\\s\\S]*enabled[\\s\\S]*true[\\s\\S]*enc[\\s\\S]*true[\\s\\S]*forage[\\s\\S]*false"
---
name: show subsystem section marks enabled subsystem in ansi block
vars:
  svars:
    westmarch_config: "ffff4444-4444-4444-4444-444444444444"
  gvars:
    ffff4444-4444-4444-4444-444444444444: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"enc": True, "forage": False},
          },
      }
      world_data = {
          "biomes": {"forest": {"gvar_id": "ffff6666-6666-6666-6666-666666666666"}},
      }
    ffff6666-6666-6666-6666-666666666666: |
      [
        [["enc.combat"], "combat", "Wolf", "", 1],
        [["enc.quest"], "quest", "Tracks", ""],
        [["enc.gather"], "flavour", "Herbs", "", "gather"]
      ]

!show subsystems
---
"re:exploration:[\\s\\S]*enabled[\\s\\S]*true[\\s\\S]*enc[\\s\\S]*true"
---
name: show subsystem section does not validate enabled subsystem data
vars:
  svars:
    westmarch_config: "ffff5555-5555-5555-5555-555555555555"
  gvars:
    ffff5555-5555-5555-5555-555555555555: |
      subsystems = {
          "exploration": {
              "enabled": True,
              "commands": {"enc": True},
          },
      }

