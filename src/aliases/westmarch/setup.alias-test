!setup
---
"re:Initial Setup[\\s\\S]*westmarch_config[\\s\\S]*\\[Westmarch config editor\\]\\(https://sykander.github.io/westmarch-generic/\\)"
---
name: unwired defaults to initial setup page

!setup
---
re:gvar create # westmarch config|subsystems =|gvar editor
---
name: initial setup includes copy-paste config create command

!setup
---
"re:General Configuration[\\s\\S]*\\[Westmarch config editor\\]\\(https://sykander.github.io/westmarch-generic/\\?westmarch_config=ffff1111-1111-1111-1111-111111111111\\)[\\s\\S]*\\[Avrae gvar dashboard\\]\\(https://avrae.io/dashboard/gvars\\?lookup=ffff1111-1111-1111-1111-111111111111\\)[\\s\\S]*\\[Westmarch Generic Discord\\]\\(https://discord.gg/ZAkJ44489G\\)"
---
name: wired defaults to general configuration page
vars:
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!setup -p 2
---
"re:General Configuration[\\s\\S]*\\[Westmarch Generic Discord\\]\\(https://discord.gg/ZAkJ44489G\\)[\\s\\S]*ask setup questions"
---
name: general configuration page links support server

!setup -p 1
---
"re:Initial Setup[\\s\\S]*westmarch_config=ffff1111-1111-1111-1111-111111111111[\\s\\S]*westmarch setup -p \"Initial Setup\""
---
name: page number can show initial setup even when wired
vars:
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!setup -p "Exploration Subsystem"
---
re:enc_biome_source|distribution_policy|command_config
---
name: title page lookup shows exploration subsystem details

!setup -p "World Data"
---
re:biomes|locations|monsters
---
name: world data page lists implemented data surfaces

!setup -p "Monster Data"
---
re:world_data.monsters|!hunt|!loot
---
name: monster data page explains hunt and loot consumers

!setup -p "Recommended Workshops"
---
re:vSheet[\s\S]*Bags[\s\S]*command_thumbnail
---
name: recommended workshops page lists companions and player setup policy
vars: