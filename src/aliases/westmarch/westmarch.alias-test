!westmarch
---
re:Dragonspeaker|Server Aliaser
---
name: unconfigured parent shows setup hint

!westmarch help
---
re:New server\?
---
name: explicit help shows onboarding hint

!westmarch check
---
re:retired|Westmarch config editor
---
name: retired check points to editor
vars:
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!westmarch
---
re:ready for this server[\s\S]*Server configurers
---
name: configured parent reports ready when no player setup checks exist
vars:
  svars:
    westmarch_config: "ffff1111-1111-1111-1111-111111111111"
  gvars:
    ffff1111-1111-1111-1111-111111111111: |
      # empty owner body

!westmarch
---
"re:Character HUD[\\s\\S]*Wallet:\\*\\* Arcane Shards: 3"
---
name: configured parent shows wallet HUD when economy wallet is enabled
vars:
  cvars:
    wg_wallet_shards: "3"
  svars:
    westmarch_config: "ffff3333-3333-3333-3333-333333333333"
  gvars:
    ffff3333-3333-3333-3333-333333333333: |
      subsystems = {
          "economy": {"enabled": True, "commands": {"wallet": True}},
      }
      currencies = {
          "shards": {"name": "Arcane Shard", "plural": "Arcane Shards"},
      }

!westmarch
---
"re:^(?![\\s\\S]*Time:\\*\\*)(?![\\s\\S]*Weather:\\*\\*)[\\s\\S]*Character HUD[\\s\\S]*Location:\\*\\* Oakwood"
---
name: configured parent defaults travel HUD to location only when travel commands are enabled
vars:
  svars:
    westmarch_config: "ffff3334-3334-3334-3334-333333333334"
  gvars:
    ffff3334-3334-3334-3334-333333333334: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"location": True, "time": True, "weather": True}},
      }
      world_data = {
          "default_location": "oakwood",
          "current_time": "Highsun",
          "current_weather": "Clear skies",
          "locations": {"oakwood": {"name": "Oakwood"}},
      }

!westmarch
---
"re:^(?![\\s\\S]*Time:\\*\\* manual)[\\s\\S]*ready for this server"
---
name: configured parent does not show manual time policy as HUD text
vars:
  svars:
    westmarch_config: "ffff3335-3335-3335-3335-333333333335"
  gvars:
    ffff3335-3335-3335-3335-333333333335: |
      subsystems = {
          "travel": {"enabled": True, "commands": {"time": True}},
      }
      policies = {
          "time": {"mode": "manual"},
          "player_setup": {"hud": {"enabled": True, "fields": ["time"]}},
      }

!westmarch
---
re:Action needed[\s\S]*vSheet[\s\S]*!vsheet setup
---
name: configured parent reports missing configured cvar check
vars:
  svars:
    westmarch_config: "ffff2222-2222-2222-2222-222222222222"
  gvars:
    ffff2222-2222-2222-2222-222222222222: |
      policies = {
          "player_setup": {
              "checks": [
                  {"type": "cvar", "key": "vsheet", "label": "vSheet", "message": "Run `!vsheet setup`."},
              ],
          },
      }

!westmarch
---
re:Ready[\s\S]*vSheet
---
name: configured parent passes configured cvar check
vars:
  cvars:
    vsheet: "ok"
  svars:
    westmarch_config: "ffff2222-2222-2222-2222-222222222222"
  gvars:
    ffff2222-2222-2222-2222-222222222222: |
      policies = {
          "player_setup": {
              "checks": [
                  {"type": "cvar", "key": "vsheet", "label": "vSheet", "message": "Run `!vsheet setup`."},
              ],
          },
      }
