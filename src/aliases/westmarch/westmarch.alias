<drac2>
using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(
    auth = env.gvars.auth,
    display = env.gvars.display,
    config = env.gvars.config,
)

ok, msg = auth.is_allowed()
get_embed = display.get_display()

if not ok:
    return get_embed(desc=msg)

args = argparse(&ARGS&)
argslist = &ARGS&

if argslist[0] in ["help", "?"]:
    return get_embed(desc = f"{ctx.command.name} help is not implemented")

return get_embed(
    desc=f"{ctx.command.name} is not implemented",
)
</drac2>

