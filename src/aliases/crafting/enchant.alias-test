!enchant help
---
"re:^(?![\\s\\S]*Potion of Healing)[\\s\\S]*Create a magic item[\\s\\S]*Cloak of Protection"
---
name: enchant help displays magic item examples
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa43"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa43: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"enchant": True},
          },
      }

!enchant "Cloak of Protection"
---
"re:Crafted \\*\\*Cloak of Protection\\*\\*"
---
name: enchant creates magic item manually
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa93"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa93: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"enchant": True},
              "config": {
                  "catalogues": {"magic_items": "engine:catalogues/magic_items"},
                  "resources": {"downtime": "manual", "gold": "manual", "items": "manual"},
                  "item_handling": {"mode": "manual"},
              },
          },
      }
