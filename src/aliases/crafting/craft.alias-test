!craft help
---
"re:^(?![\\s\\S]*Potion of Healing)(?![\\s\\S]*Cloak of Protection)[\\s\\S]*Create an item[\\s\\S]*Rope, Hemp"
---
name: craft help displays mundane examples
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa41"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa41: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"craft": True},
          },
      }

!craft Pony
---
"re:Crafted \\*\\*Pony\\*\\*"
---
name: craft creates mundane item manually
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa5"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa5: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"craft": True},
              "config": {
                  "catalogues": {"items": "engine:catalogues/items"},
                  "resources": {"downtime": "manual", "gold": "manual"},
                  "item_handling": {"mode": "manual"},
              },
          },
      }
