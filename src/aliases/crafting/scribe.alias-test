!scribe help
---
"re:Create a spell scroll[\\s\\S]*-i[\\s\\S]*Misty Step"
---
name: scribe help displays ignore option
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa44"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa44: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"scribe": True},
          },
      }

!scribe Fireball -l 5
---
"re:Scroll of Fireball \\(5th Lv\\.\\)"
---
name: scribe uses 2014 scroll name
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa7"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa7: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"scribe": True},
              "config": {
                  "catalogues": {"spells": "engine:catalogues/spells"},
                  "resources": {"downtime": "manual", "gold": "manual", "spell_slot": "manual"},
                  "item_handling": {"mode": "manual"},
              },
              "command_config": {"scribe": {"rules_version": "2014", "require_known_spell": False}},
          },
      }

!scribe House Spark
---
re:No level 2 spell slots available\. Use -i to bypass this check\.
---
name: scribe slot failure mentions ignore flag
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa45"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa45: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"scribe": True},
              "config": {
                  "rules_version": "2014",
                  "catalogues": {"spells": {"entries": [{"name": "House Spark", "level": 2}]}},
                  "resources": {"downtime": "manual", "gold": "manual", "spell_slot": "check"},
                  "item_handling": {"mode": "manual"},
              },
              "command_config": {"scribe": {"require_known_spell": False}},
          },
      }
character:
  spellbook:
    slots:
      2: 0

!scribe House Spark -i
---
"re:Crafted \\*\\*Scroll of House Spark[\\s\\S]*Ignore mode used: known-spell and spell-slot checks were bypassed\\."
---
name: scribe ignore bypasses known spell and slot checks
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa46"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaa46: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"scribe": True},
              "config": {
                  "rules_version": "2014",
                  "catalogues": {"spells": {"entries": [{"name": "House Spark", "level": 2}]}},
                  "resources": {"downtime": "manual", "gold": "manual", "spell_slot": "check"},
                  "item_handling": {"mode": "manual"},
              },
          },
      }
character:
  spellbook:
    slots:
      2: 0

!scribe Fireball -l 5 -sb 3 -dc 11
---
"re:Scroll of Fireball \\(Lv\\. 5 \\| SB \\+3 \\| DC 11\\)"
---
name: scribe uses 2024 scroll name with use stats
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa8"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa8: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"scribe": True},
              "config": {
                  "catalogues": {"spells": "engine:catalogues/spells"},
                  "rules_version": "2024",
                  "resources": {"downtime": "manual", "gold": "manual", "spell_slot": "manual"},
                  "item_handling": {"mode": "manual"},
              },
              "command_config": {"scribe": {"require_known_spell": False}},
          },
      }

!scribe House Spark
---
re:must know or have prepared
---
name: scribe rejects spell not in character spellbook by default
vars:
  svars:
    westmarch_config: "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa9"
  gvars:
    aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaa9: |
      subsystems = {
          "crafting": {
              "enabled": True,
              "commands": {"scribe": True},
              "config": {
                  "rules_version": "2014",
                  "catalogues": {"spells": {"entries": [{"name": "House Spark", "level": 1}]}},
                  "resources": {"downtime": "manual", "gold": "manual", "spell_slot": "manual"},
                  "item_handling": {"mode": "manual"},
              },
          },
      }
