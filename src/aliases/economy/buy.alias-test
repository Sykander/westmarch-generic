      shops = {
          "general": {
              "id": "general",
              "name": "General Store",
              "stock": [{"item": "Herbalism Kit", "price": {"gold": 0}}],
          },
      }
character:
  cvars:
    bags: '[["Equipment", {}]]'

!buy "Herbalism Kit" yes
