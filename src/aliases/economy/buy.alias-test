              "enabled": True,
              "commands": {"buy": True},
              "config": {"ask_to_confirm_purchases": True},
          },
      }
      shops = {
          "general": {
              "id": "general",
              "name": "General Store",
              "stock": [{"item": "Herbalism Kit", "price": {"gold": 0}}],
          },
      }
character:
  cvars:
    bags: '[["Equipment", {}]]'

