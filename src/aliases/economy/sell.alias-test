!sell rope
---
re:Sold \*\*1x Rope, Hemp \(50 ft\)\*\*
---
name: sell sells a held configured stock item
vars:
  svars:
    westmarch_config: "eeee1000-1000-1000-1000-100000000003"
  gvars:
    eeee1000-1000-1000-1000-100000000003: |
      subsystems = {
          "economy": {"enabled": True, "commands": {"sell": True}},
      }
      shops = {
          "general": {
              "id": "general",
              "name": "General Store",
              "accepts_sells": True,
              "stock": [{"item": "Rope, Hemp (50 ft)", "price": {"gold": 0}}],
          },
      }
character:
  cvars:
    bags: '[["Equipment", {"Rope, Hemp (50 ft)": 1}]]'

!sell stabling
---
re:is a service and cannot be sold
---
name: sell rejects service stock rows
vars:
  svars:
    westmarch_config: "eeee1000-1000-1000-1000-100000000006"
  gvars:
    eeee1000-1000-1000-1000-100000000006: |
      subsystems = {
          "economy": {"enabled": True, "commands": {"sell": True}},
      }
      shops = {
          "stables": {
              "id": "stables",
              "name": "Stable Yard",
              "accepts_sells": True,
              "stock": [{"item": "Stabling (1 day)", "price": {"gold": 0}, "fulfillment": "service"}],
          },
      }
character:
  cvars:
    bags: '[["Equipment", {"Stabling (1 day)": 1}]]'

!sell general rope
---
re:not buying items
---
name: sell rejects shops that do not accept sells
vars:
  svars:
    westmarch_config: "eeee1000-1000-1000-1000-100000000004"
  gvars:
    eeee1000-1000-1000-1000-100000000004: |
      subsystems = {
          "economy": {"enabled": True, "commands": {"sell": True}},
      }
      shops = {
          "general": {
              "id": "general",
              "name": "General Store",
              "accepts_sells": False,
              "stock": [{"item": "Rope, Hemp (50 ft)", "price": {"gold": 0}}],
          },
      }
character:
  cvars:
    bags: '[["Equipment", {"Rope, Hemp (50 ft)": 1}]]'

!sell rope
---
re:No visible shops are buying[\s\S]*accepts_sells
---
name: sell explains missing accepting shop setup
vars:
  svars:
    westmarch_config: "eeee1000-1000-1000-1000-100000000005"
  gvars:
    eeee1000-1000-1000-1000-100000000005: |
      subsystems = {
          "economy": {"enabled": True, "commands": {"sell": True}},
      }
      shops = {
          "general": {
              "id": "general",
              "name": "General Store",
              "accepts_sells": False,
              "stock": [{"item": "Rope, Hemp (50 ft)", "price": {"gold": 0}}],
          },
      }
character:
  cvars:
    bags: '[["Equipment", {"Rope, Hemp (50 ft)": 1}]]'
