<drac2>
using(env="00000000-0000-0000-0000-000000000001")
using(
    example = env.gvars.example,
)

argslist = &ARGS&

if len(argslist) == 0 or argslist[0] in ["help", "?"]:
    return f"""Example command for {example.server_name}.

Usage: `{ctx.prefix}example`
Use `{ctx.prefix}example sub` for the subcommand."""

return "Example command ran."
</drac2>
