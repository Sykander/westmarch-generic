[{"id":"example_brew_healing","name":"Potion of Healing","kind":"brew","workdays":2,"consumed":[{"item":"Arnica","qty":2},{"item":"Crystal vial","qty":1}],"required":[],"spells":[],"tags":["potion","healing","example"],"description":"Reduce the herbs in a clean vessel over a gentle heat, then seal the vial and agitate the infusion until it glows faintly red. The draught is finished when the colour holds at room temperature."},{"id":"example_craft_healers_kit","name":"Healer's Kit","kind":"craft","workdays":1,"consumed":[{"item":"Leather","qty":1},{"item":"Herbs","qty":1},{"item":"Linen","qty":2}],"required":[],"spells":[],"tags":["item","healing","example"],"description":"Cut and stitch a leather wrap, fold linen into dressings, and pack salves in a watertight pouch. Test every strap and closure before the kit is fit to carry."},{"id":"example_enchant_cloak_of_protection","name":"Cloak of Protection","kind":"enchant","workdays":5,"consumed":[{"item":"Diamond (100 gp)","qty":1},{"item":"Incense","qty":3}],"required":[{"item":"Cloak","qty":1}],"spells":["Warding Bond"],"tags":["magic item","protection","example"],"description":"Lay the cloak flat and inscribe warding sigils along the hem while blessed incense burns. At the ritual's peak, cast Warding Bond over the garment to bind the wards in place."}]