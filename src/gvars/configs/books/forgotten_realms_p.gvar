[{"name":"Planar Travels: A Study of the Planes of Good","author":"Elminster","written":"before 1371 DR","rarity":"very rare","language":"Common","type":"original","description":"Planar Travels: A Study of the Planes of Good — A treatise on magic as it is actually practiced — wards, reputations, and the price of mispronunciation. Elminster is credited in library catalogues; the work is dated to before 1371 DR.\n\nComplete copies are rare; excerpted versions circulate among mages who insist the missing pages do not matter.","tags":["arcane","religion","philosophy"],"read_bonus":0,"content_link":"https://forgottenrealms.fandom.com/wiki/Planar_Travels%3A_A_Study_of_the_Planes_of_Good"}]