True
---
name: Forgotten Realms 2014 config enables travel and economy with production data gvars

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(library = env.gvars.library)
wd = {}
for key in forgotten_realms_2014.world_data:
    wd[key] = forgotten_realms_2014.world_data[key]
wd["book_gvar_ids"] = [
    env.gvars.forgotten_realms_a,
    env.gvars.forgotten_realms_b,
    env.gvars.forgotten_realms_c,
    env.gvars.forgotten_realms_d,
    env.gvars.forgotten_realms_e,
    env.gvars.forgotten_realms_f,
    env.gvars.forgotten_realms_g,
    env.gvars.forgotten_realms_h,
    env.gvars.forgotten_realms_i,
    env.gvars.forgotten_realms_j,
    env.gvars.forgotten_realms_k,
    env.gvars.forgotten_realms_l,
    env.gvars.forgotten_realms_m,
    env.gvars.forgotten_realms_n,
    env.gvars.forgotten_realms_o,
    env.gvars.forgotten_realms_pq,
    env.gvars.forgotten_realms_r,
    env.gvars.forgotten_realms_s,
    env.gvars.forgotten_realms_t,
    env.gvars.forgotten_realms_v,
    env.gvars.forgotten_realms_w,
]
cfg = {
    "subsystems": forgotten_realms_2014.subsystems,
    "world_data": wd,
}
books = library.catalogue_entries(cfg)
found = False
for book in books:
    if library.book_name(book) == "A Sage's Travel Guide to the North":
        found = True
return len(books) == 185 and found
