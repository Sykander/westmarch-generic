wd = forgotten_realms_2014.world_data
travel = forgotten_realms_2014.subsystems["travel"]
economy = forgotten_realms_2014.subsystems["economy"]
return (
    forgotten_realms_2014.rules_version == "2014"
    and wd["default_location"] == "waterdeep"
    and wd["locations_gvar_id"] == "6c50e5a7-e36b-49fe-96e7-7e82e157bd31"
    and wd["paths_gvar_id"] == "40403500-be2c-4b1a-8170-6176adf87aa5"
    and travel["enabled"] == True
    and travel["commands"]["travel"] == True
    and travel["commands"]["location"] == True
    and travel["config"]["show_arrival_time"] == True
    and travel["config"]["show_arrival_weather"] == True
    and economy["enabled"] == True
    and economy["commands"]["job"] == True
    and economy["commands"]["buy"] == True
    and economy["commands"]["sell"] == True
    and economy["config"]["job_location_policy"] == "check"
    and len(economy["config"]["jobs"]) >= 4
    and len(forgotten_realms_2014.shops) >= 30
    and forgotten_realms_2014.shops["waterdeep_general_market"]["location_id"] == "waterdeep"
)
---
True
---
name: Forgotten Realms 2014 config enables travel and economy with production data gvars

waterdeep_docks = forgotten_realms_2014.shops["waterdeep_docks"]
waterdeep_market = forgotten_realms_2014.shops["waterdeep_general_market"]
item_overlay = forgotten_realms_2014.subsystems["crafting"]["config"]["catalogues"]["items"]
return (
    waterdeep_docks["location_id"] == "waterdeep"
    and waterdeep_docks["stock"][0]["item"] == "Ship Passage"
    and waterdeep_market["accepts_sells"] == True
    and item_overlay["include_engine"] == True
    and item_overlay["entries"][0]["name"] == "Ship Passage"
)
---
True
---
name: Forgotten Realms 2014 shops include Waterdeep market and service item overlay

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(
    journeys = env.gvars.journeys,
    locations = env.gvars.locations,
)
wd = {}
for key in forgotten_realms_2014.world_data:
    wd[key] = forgotten_realms_2014.world_data[key]
wd["locations_gvar_id"] = "fde0dbeb-d2e3-42fd-8f56-2d94bdf3ac58"
wd["paths_gvar_id"] = "19623e1a-3a23-49a0-9d40-986fdd26d7e7"
cfg = {
    "rules_version": forgotten_realms_2014.rules_version,
    "display": forgotten_realms_2014.display,
    "subsystems": forgotten_realms_2014.subsystems,
    "world_data": wd,
}
ch = character()
current_id, current_loc = journeys.get_location(ch, cfg)
desc = locations.display_location(current_loc, "full", ch, True, journeys.get_visit_count(ch, current_id))
nearby = journeys.format_nearby_locations(cfg, current_id, "!")
return current_id == "waterdeep" and "Waterdeep" in desc and "## Nearby" in nearby and "High Road" in nearby and "Trade Way" in nearby
---
True
---
name: location command core shows Waterdeep nearby routes under statement budget

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(
    journeys = env.gvars.journeys,
    locations = env.gvars.locations,
)
wd = {}
for key in forgotten_realms_2014.world_data:
    wd[key] = forgotten_realms_2014.world_data[key]
wd["locations_gvar_id"] = "fde0dbeb-d2e3-42fd-8f56-2d94bdf3ac58"
wd["paths_gvar_id"] = "19623e1a-3a23-49a0-9d40-986fdd26d7e7"
cfg = {
    "rules_version": forgotten_realms_2014.rules_version,
    "display": forgotten_realms_2014.display,
    "subsystems": forgotten_realms_2014.subsystems,
    "world_data": wd,
}
ch = character()
current_id, current_loc = journeys.get_location(ch, cfg)
matches = locations.search_locations(cfg, "silverymoon")
dest_id = locations.location_id(matches[0]) if len(matches) == 1 else None
found, route = journeys.find_journey(cfg, current_id, dest_id)
journey = journeys.build_journey(cfg, current_id, dest_id, route)
desc = locations.display_location(current_loc, "full", ch, True, journeys.get_visit_count(ch, current_id))
desc += "\n\n" + journeys.display_journey(cfg, journey, "detailed", prefix="!")
return current_id == "waterdeep" and found and len(route) == 8 and route[len(route) - 1]["to"] == "silverymoon" and "Waterdeep" in desc and "Silverymoon" in desc and "!enc" in desc
