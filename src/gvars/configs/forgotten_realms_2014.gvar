        {"from": "high_road", "to": "leilon", "label": "High Road", "requirements": {"transport": ["walk", "horse", "cart"]}, "steps": [{"type": "encounter", "biome": "road"}, {"type": "proceed", "description": "Pass the Mere of Dead Men and make for Leilon's rebuilt streets."}]},
        {"from": "leilon", "to": "high_road", "label": "High Road", "requirements": {"transport": ["walk", "horse", "cart"]}, "steps": [{"type": "proceed", "description": "Leave Leilon and rejoin the High Road between marsh and sea."}, {"type": "encounter", "biome": "road"}]},
        {"from": "leilon", "to": "neverwinter", "label": "High Road", "requirements": {"transport": ["walk", "horse", "cart"]}, "steps": [{"type": "encounter", "biome": "road"}, {"type": "proceed", "description": "Keep north along the coast until Neverwinter's warm river air reaches the road."}]},
        {"from": "neverwinter", "to": "leilon", "label": "High Road", "requirements": {"transport": ["walk", "horse", "cart"]}, "steps": [{"type": "proceed", "description": "Take the High Road south from Neverwinter toward Leilon."}, {"type": "encounter", "biome": "road"}]},
        {"from": "neverwinter", "to": "port_llast", "label": "High Road", "requirements": {"transport": ["walk", "horse", "cart"]}, "steps": [{"type": "encounter", "biome": "road"}, {"type": "proceed", "description": "Follow the northern coast road to the quarries and docks of Port Llast."}]},
        {"from": "port_llast", "to": "neverwinter", "label": "High Road", "requirements": {"transport": ["walk", "horse", "cart"]}, "steps": [{"type": "proceed", "description": "Turn south from Port Llast and keep the sea to your right toward Neverwinter."}, {"type": "encounter", "biome": "road"}]},
        {"from": "port_llast", "to": "luskan", "label": "High Road", "requirements": {"transport": ["walk", "horse", "cart"]}, "steps": [{"type": "encounter", "biome": "road"}, {"type": "proceed", "description": "The road bends north through colder wind toward Luskan and the River Mirar."}]},
