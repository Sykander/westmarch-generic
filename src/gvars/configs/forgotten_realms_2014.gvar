        {"from": "trade_way", "to": "waterdeep", "label": "Trade Way", "requirements": {"transport": ["walk", "horse", "cart"]}, "steps": [{"type": "encounter", "biome": "road"}, {"type": "proceed", "description": "Follow the northbound caravans back toward Waterdeep."}]},
        {"from": "trade_way", "to": "daggerford", "label": "Trade Way", "requirements": {"transport": ["walk", "horse", "cart"]}, "steps": [{"type": "encounter", "biome": "road"}, {"type": "proceed", "description": "Keep to the river valley until Daggerford's walls and bridge come into view."}]},
