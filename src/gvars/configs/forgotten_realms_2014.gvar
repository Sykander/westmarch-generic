            "catalogues": {
                "items": {
                    "include_engine": True,
                    "entries": [
                        {"name": "Ship Passage", "rarity": "mundane", "type": "Service", "value": "25 gp"},
                        {"name": "River Passage", "rarity": "mundane", "type": "Service", "value": "5 gp"},
                        {"name": "Small Boat Hire", "rarity": "mundane", "type": "Service", "value": "10 gp"},
                        {"name": "Keelboat Passage", "rarity": "mundane", "type": "Service", "value": "15 gp"},
                        {"name": "Caravan Passage", "rarity": "mundane", "type": "Service", "value": "3 gp"},
                        {"name": "Stabling (1 day)", "rarity": "mundane", "type": "Service", "value": "5 sp"},
