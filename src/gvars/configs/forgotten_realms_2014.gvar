                    ],
                },
                "potions": "engine:catalogues/potions",
                "spells": "engine:catalogues/spells",
                "magic_items": "engine:catalogues/magic_items",
                "recipes": [{"id":"waterdeep_temple_healing_draught","name":"Potion of Healing","kind":"brew","workdays":1,"gold":25,"consumed":[{"item":"Arnica","qty":2},{"item":"Crystal vial","qty":1},{"item":"Holy Water (flask)","qty":1}],"required":[],"spells":["Cure Wounds"],"tools":["Herbalism Kit","Alchemist's Supplies"],"tags":["waterdeep","sword_coast","temple","healing","potion"],"description":"A practical temple draught used by Waterdeep field healers. Steep arnica in warmed holy water, skim the bitter foam, and seal the vial while a curing prayer is spoken over the red infusion."},{"id":"waterdeep_triage_greater_healing","name":"Potion of Healing, Greater","kind":"brew","workdays":5,"gold":100,"consumed":[{"item":"Arnica","qty":5},{"item":"Mooncap","qty":2},{"item":"Crystal vial","qty":1},{"item":"Holy Water (flask)","qty":2}],"required":[],"spells":["Cure Wounds","Prayer of Healing"],"tools":["Herbalism Kit","Alchemist's Supplies"],"tags":["waterdeep","temple","healing","potion"],"description":"A stronger battlefield version for caravan guards and city watch triage. The mooncap must be bruised under silver light before the final prayer or the mixture settles as ordinary medicine."},{"id":"candlekeep_midnight_vigil_tonic","name":"Potion of Watchful Rest","kind":"brew","workdays":2,"gold":50,"consumed":[{"item":"Black tea","qty":2},{"item":"Ink (1 oz)","qty":1},{"item":"Crystal vial","qty":1}],"required":[],"spells":["Alarm"],"tools":["Herbalism Kit","Calligrapher's Supplies"],"tags":["candlekeep","library","vigil","potion"],"description":"An archivist's tonic for all-night copying work. Bitter tea is reduced with a thread of ink, then the bottle is marked with a tiny alarm sigil that keeps sleep from taking hold."},{"id":"sword_coast_deep_breath_elixir","name":"Potion of Water Breathing","kind":"brew","workdays":10,"gold":200,"consumed":[{"item":"Kelp","qty":3},{"item":"Pearl dust","qty":1},{"item":"Crystal vial","qty":1}],"required":[],"spells":["Water Breathing"],"tools":["Herbalism Kit","Alchemist's Supplies"],"tags":["sword_coast","sea_of_swords","mariner","potion"],"description":"Mariners from the Sword Coast keep this recipe for wreck salvage and storm rescue. Grind pearl dust into kelp broth until it shines like surf, then breathe across the open vial as the spell settles."},{"id":"icewind_chardalyn_coldward","name":"Potion of Resistance","kind":"brew","workdays":10,"gold":200,"consumed":[{"item":"Winter lichen","qty":3},{"item":"Chardalyn splinter","qty":1},{"item":"Crystal vial","qty":1}],"required":[],"spells":["Protection from Energy"],"tools":["Herbalism Kit","Alchemist's Supplies"],"tags":["icewind_dale","ten_towns","chardalyn","resistance","potion"],"description":"A Ten-Towns warding brew made with a carefully neutralized chardalyn shaving. The lichen must freeze solid before heating, or the potion takes on an unstable black sheen."},{"id":"phandalin_goat_path_climbing_mix","name":"Potion of Climbing","kind":"brew","workdays":1,"gold":25,"consumed":[{"item":"Goat tallow","qty":1},{"item":"Spider silk","qty":1},{"item":"Crystal vial","qty":1}],"required":[],"spells":["Spider Climb"],"tools":["Herbalism Kit","Alchemist's Supplies"],"tags":["phandalin","triboar_trail","mine","climbing","potion"],"description":"A miner's shortcut recipe from the foothills around Phandalin. Render goat tallow with spider silk, then shake the vial against rough stone until the mixture clings to the glass."},{"id":"reghed_frost_giant_sinew_draught","name":"Potion of Giant Strength, Frost","kind":"brew","workdays":50,"gold":2000,"consumed":[{"item":"Frost giant sinew","qty":1},{"item":"Blue ice chips","qty":3},{"item":"Crystal vial","qty":1}],"required":[],"spells":["Enhance Ability"],"tools":["Alchemist's Supplies"],"tags":["icewind_dale","reghed","giant","strength","potion"],"description":"A dangerous northern draught brewed in a snow-packed crucible. The sinew is never boiled; it is flexed through the liquid until the elixir remembers the giant's strength."},{"id":"lords_alliance_lionheart_elixir","name":"Potion of Heroism","kind":"brew","workdays":50,"gold":2000,"consumed":[{"item":"Golden mane thread","qty":1},{"item":"Blessed wine","qty":2},{"item":"Crystal vial","qty":1}],"required":[],"spells":["Bless","Heroism"],"tools":["Herbalism Kit","Alchemist's Supplies"],"tags":["sword_coast","lords_alliance","heroism","potion"],"description":"A ceremonial elixir carried by captains before desperate sorties. The brewer whispers the names of three saved settlements into the wine before the blessing is sealed."},{"id":"field_chirurgeons_healers_kit","name":"Healer's Kit","kind":"craft","workdays":1,"gold":2.5,"consumed":[{"item":"Linen","qty":2},{"item":"Herbs","qty":1},{"item":"Leather","qty":1}],"required":[],"spells":[],"tools":["Leatherworker's Tools","Herbalism Kit"],"tags":["waterdeep","temple","healing","gear"],"description":"A compact field kit used on the Long Road. Stitch the wrap from boiled leather, pack dry dressings by size, and tuck the salves where they will not break during a hurried ride."},{"id":"waterdeep_guild_alchemists_fire","name":"Alchemist's Fire (flask)","kind":"craft","workdays":5,"gold":25,"consumed":[{"item":"Oil (flask)","qty":2},{"item":"Sulfur","qty":1},{"item":"Glass Bottle","qty":1}],"required":[],"spells":["Continual Flame"],"tools":["Alchemist's Supplies"],"tags":["waterdeep","guild","alchemical","fire"],"description":"A guild-safe flask recipe with a strict cooling step. The flame is coaxed into the oil only after the stopper is waxed, leaving the bottle quiet until it breaks."},{"id":"mere_dead_men_antitoxin","name":"Antitoxin (vial)","kind":"craft","workdays":5,"gold":25,"consumed":[{"item":"Adder venom","qty":1},{"item":"Marsh herb","qty":2},{"item":"Vial","qty":1}],"required":[],"spells":["Protection from Poison"],"tools":["Herbalism Kit"],"tags":["high_road","mere_of_dead_men","poison","medicine"],"description":"A swamp-road antidote made by cutting venom with three marsh herbs at different heats. The finished vial smells foul, but the green ring at its neck marks a good batch."},{"id":"candlekeep_luminary_ink","name":"Ink (1 oz)","kind":"craft","workdays":1,"gold":5,"consumed":[{"item":"Lampblack","qty":1},{"item":"Iron filings","qty":1},{"item":"Gum resin","qty":1}],"required":[],"spells":[],"tools":["Calligrapher's Supplies"],"tags":["candlekeep","scribe","ink","library"],"description":"A durable black ink for copied maps and spell marginalia. Grind the filings until no grit remains, then fold in lampblack while reciting the page numbers the ink will guard."},{"id":"silverymoon_bound_spellbook","name":"Spellbook","kind":"craft","workdays":5,"gold":25,"consumed":[{"item":"Book","qty":1},{"item":"Ink (1 oz)","qty":2},{"item":"Parchment (1 sheet)","qty":20},{"item":"Leather","qty":1}],"required":[],"spells":["Arcane Lock","Identify"],"tools":["Calligrapher's Supplies","Leatherworker's Tools"],"tags":["silverymoon","arcane","scribe","spellbook"],"description":"A Silver Marches binding with reinforced signatures and a modest lock charm. The cover is tooled last so the book's true owner can add their mark."},{"id":"candlekeep_scroll_case","name":"Case, Map/Scroll","kind":"craft","workdays":1,"gold":0.5,"consumed":[{"item":"Leather","qty":1},{"item":"Waxed cord","qty":1},{"item":"Parchment (1 sheet)","qty":1}],"required":[],"spells":[],"tools":["Leatherworker's Tools","Calligrapher's Supplies"],"tags":["candlekeep","scribe","map","travel"],"description":"A waterproof scroll case sized for coastal travel. The inner seam is rubbed with wax and copied with three small reference marks so librarians know which side stayed dry."},{"id":"ten_towns_storm_lantern","name":"Lantern - Hooded","kind":"craft","workdays":1,"gold":2.5,"consumed":[{"item":"Brass fittings","qty":1},{"item":"Glass Bottle","qty":1},{"item":"Oil (flask)","qty":1}],"required":[],"spells":[],"tools":["Tinker's Tools"],"tags":["icewind_dale","ten_towns","travel","lantern"],"description":"A hooded lantern adjusted for blowing snow and sudden darkness. File the vents narrow, fit the glass deep, and test the hinge until it opens with gloved fingers."},{"id":"silverymoon_bridge_silk_rope","name":"Rope, Silk (50 ft)","kind":"craft","workdays":2,"gold":5,"consumed":[{"item":"Silk cord","qty":5},{"item":"Silver thread","qty":1}],"required":[],"spells":[],"tools":["Weaver's Tools"],"tags":["silverymoon","moonbridge","travel","rope"],"description":"A bright bridge-runner's rope braided with one silver guide thread. It is not magical, but the thread shows strain before the rope gives way."},{"id":"netherese_echo_driftglobe","name":"Driftglobe","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"Crystal","qty":1},{"item":"Silver dust","qty":2},{"item":"Glowmoss","qty":1}],"required":[],"spells":["Light","Daylight"],"tools":["Jeweler's Tools","Glassblower's Tools"],"tags":["netherese","phandelver","obelisk","light","magic_item"],"description":"A small crystal globe patterned after ruins and old Netherese geometry. The crafter sets a Daylight lattice inside the glass, then trims the glow until it floats without heat."},{"id":"blackstaff_apprentice_brooch","name":"Brooch of Shielding","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"Silver wire","qty":2},{"item":"Smoky quartz","qty":1}],"required":[{"item":"Fine brooch","qty":1}],"spells":["Shield"],"tools":["Jeweler's Tools"],"tags":["waterdeep","blackstaff","warding","protection","magic_item"],"description":"A restrained Waterdhavian warding brooch for apprentices who attract trouble. Twist the silver wire into a closed knot, set the quartz over it, and strike the Shield pattern before polishing."},{"id":"harper_waystone_pair","name":"Sending Stones","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"River stone","qty":2},{"item":"Silver wire","qty":1},{"item":"Blue sealing wax","qty":1}],"required":[],"spells":["Sending"],"tools":["Mason's Tools","Jeweler's Tools"],"tags":["harpers","silverymoon","everlund","communication","magic_item"],"description":"Two plain stones for couriers who cannot risk visible script. Each stone is wrapped with the other's silver thread before the Sending charge is divided between them."},{"id":"candlekeep_pearl_of_recall","name":"Pearl of Power","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"Pearl","qty":1},{"item":"Ink (1 oz)","qty":1},{"item":"Silver dust","qty":1}],"required":[],"spells":["Identify"],"tools":["Jeweler's Tools","Calligrapher's Supplies"],"tags":["candlekeep","arcane","pearl","spellcasting","magic_item"],"description":"A scholar's focus pearl marked with one invisible index rune. The pearl is rolled across the inked rune until it drinks the mark and returns a spell-memory echo."},{"id":"mithral_hall_moonmail","name":"Mithral Armor","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"Mithral trace","qty":3},{"item":"Silver dust","qty":2}],"required":[{"item":"Chain Mail","qty":1}],"spells":["Fabricate"],"tools":["Smith's Tools"],"tags":["mithral_hall","dwarf","mithral","armor","magic_item"],"description":"A light mail process taught by deep smiths who hate wasted ore. Work the mithral trace into every stress ring, then use Fabricate only after the mundane fit is perfect."},{"id":"citadel_adbar_starfall_plate","name":"Adamantine Armor","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"Adamantine ore","qty":3},{"item":"Coal","qty":5}],"required":[{"item":"Chain Mail","qty":1}],"spells":["Fabricate"],"tools":["Smith's Tools"],"tags":["citadel_adbar","dwarf","adamantine","armor","magic_item"],"description":"A fortress pattern for armor that turns terrible blows aside. The adamantine is folded into the impact plates first, leaving the rest of the mail flexible enough to march."},{"id":"cormanthor_shadowleaf_cloak","name":"Cloak of Elvenkind","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"Shadowleaf dye","qty":2},{"item":"Moon thread","qty":2}],"required":[{"item":"Cloak","qty":1}],"spells":["Invisibility"],"tools":["Weaver's Tools"],"tags":["cormanthor","elves","stealth","forest","magic_item"],"description":"A quiet forest cloak dyed under branches that never see noon. The final stitch is pulled while the Invisibility veil is active, making the hem blur against leaves and stone."},{"id":"phandelver_silkline_rope","name":"Rope of Climbing","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"Spider silk","qty":3},{"item":"Silver clasp","qty":1}],"required":[{"item":"Rope, Silk (50 ft)","qty":1}],"spells":["Spider Climb"],"tools":["Weaver's Tools"],"tags":["phandalin","wave_echo_cave","mine","climbing","magic_item"],"description":"A mine-rescue line inspired by old cave workings. Braid spider silk through the rope's heart, set a silver clasp at one end, and teach the rope three climbing knots."},{"id":"candlekeep_folded_satchel","name":"Bag of Holding","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"Phase silk","qty":2},{"item":"Blue chalk","qty":1}],"required":[{"item":"Backpack","qty":1}],"spells":["Rope Trick"],"tools":["Weaver's Tools","Calligrapher's Supplies"],"tags":["candlekeep","library","storage","magic_item"],"description":"A librarian's impossible satchel for moving books without a cart. Chalk the inside seams in four folding angles, then hold the Rope Trick space open while the lining is sewn shut."},{"id":"silverymoon_apprentice_wand","name":"Wand of Magic Missiles","kind":"enchant","workdays":10,"gold":200,"consumed":[{"item":"Yew wand core","qty":1},{"item":"Amber","qty":1}],"required":[{"item":"Wand","qty":1}],"spells":["Magic Missile"],"tools":["Woodcarver's Tools","Jeweler's Tools"],"tags":["silverymoon","arcane","wand","force","magic_item"],"description":"An apprentice wand with a clean force channel and no flourish. Sand the yew around a straight amber vein, then release the first Magic Missile into a slate target before sealing the grip."}],
