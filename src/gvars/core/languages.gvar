LANGUAGE_NAMES = []
for _k in _LANGUAGES.keys():
    LANGUAGE_NAMES.append(_k)


def _active_character():
    try:
        return character()
    except:
        return None


def _resolve_optional_character(char = None):
    return char if char != None else _active_character()


def _require_character(char = None, context: str = "this operation"):
    c = _resolve_optional_character(char)
    if c == None:
        err(f"No character available for {context}.")
    return c


def _parse_languages_from_cvar_value(raw) -> list:
    """Split a ``languages`` cvar string into stripped tokens (commas or semicolons)."""
    if raw == None:
        return []
    text = str(raw).strip()
    if text == "":
        return []

    unified = text.replace(";", ",")
    out = []
    for chunk in unified.split(","):
        t = chunk.strip()
        if t != "":
            out.append(t)
    return out


def _canonicalize_language_token(token: str) -> str:
    """Resolve to a canonical catalog name, or ``None``. Ambiguous tokens (e.g. bare ``Human``) return ``None``."""
    if token == None:
        return None
    s = str(token).strip()
    if s == "":
        return None

    sl = s.lower()

    for _canon, _spec in _LANGUAGES.items():
        for _al in _spec["aliases"]:
            if str(_al).lower() == sl:
                return _canon

    for n in LANGUAGE_NAMES:
        if n == s:
            return n

    ci_hits = []
    for n in LANGUAGE_NAMES:
        if str(n).lower() == sl:
            ci_hits.append(n)
    if len(ci_hits) == 1:
        return ci_hits[0]
    if len(ci_hits) > 1:
        return None

    sub_hits = []
    sub_seen = {}
    for n in LANGUAGE_NAMES:
        nl = str(n).lower()
        if _name_subtoken_match(nl, sl):
            if sub_seen.get(n, False) == False:
                sub_seen[n] = True
                sub_hits.append(n)
    for _canon, _spec in _LANGUAGES.items():
        for _al in _spec["aliases"]:
            al_l = str(_al).lower()
            if _name_subtoken_match(al_l, sl):
                if sub_seen.get(_canon, False) == False:
                    sub_seen[_canon] = True
                    sub_hits.append(_canon)
    if len(sub_hits) == 1:
        return sub_hits[0]
    if len(sub_hits) > 1:
        return None

    rev_hits = []
    for n in LANGUAGE_NAMES:
        nl = str(n).lower()
        if nl in sl:
            rev_hits.append(n)
    for _canon, _spec in _LANGUAGES.items():
        for _al in _spec["aliases"]:
            _al_l = str(_al).lower()
            if _al_l in sl:
                rev_hits.append(_canon)
    if len(rev_hits) == 1:
        return rev_hits[0]
    return None


def _get_similarity(lang_from: str, lang_to: str, method: str = "vocal") -> int:
    """Directed similarity 0–100 on ``method``: reads ``methods[method].similar_to[lang_to]`` (not necessarily symmetric)."""
    method = _normalize_communication_method(method)
    ca = _canonicalize_language_token(lang_from)
    cb = _canonicalize_language_token(lang_to)
    if ca == None or cb == None:
        return 0
    if ca == cb:
        return 100
    slot = _LANGUAGES[ca]["methods"].get(method, False)
    if slot == False:
        return 0
    st = slot.get("similar_to", None)
    if st == None:
        return 0
    return int(st.get(cb, 0))


def _get_languages_cvar_raw(char = None) -> str:
    """The raw ``languages`` cvar string (empty string if unset)."""
    char = _require_character(char, "languages cvar")
    v = char.get_cvar(_languages_cvar_key, "")
    if v == None:
        return ""
    return str(v)


def _get_sheet_language_tokens(char = None) -> list:
    """Tokens from the ``languages`` cvar after splitting (not necessarily catalog names)."""
    raw = _get_languages_cvar_raw(char)
    return _parse_languages_from_cvar_value(raw)


def get_character_languages(char = None) -> list:
    """Public: canonical catalog names from the character's ``languages`` cvar (tokens that resolve, including via aliases)."""
    char = _require_character(char, "known languages")
    out = []
    seen = {}
    for tok in _get_sheet_language_tokens(char):
        c = _canonicalize_language_token(tok)
        if c != None and seen.get(c, False) == False:
            seen[c] = True
            out.append(c)
    return out


def _character_knows_language(target: str, known: list) -> bool:
    for _k in known:
        if _k == target:
            return True
    return False


def _class_granted_languages(char) -> list:
    """Class features that grant languages without listing them on the ``languages`` cvar."""
    if char == None:
        return []
    try:
        lv = char.levels
    except:
        return []
    if lv == None:
        return []
    out = []
    try:
        if int(lv.get("Rogue") or 0) >= 1 and _LANGUAGES.get("Thieves' Cant") != None:
            out.append("Thieves' Cant")
    except:
        pass
    try:
        if int(lv.get("Druid") or 0) >= 1 and _LANGUAGES.get("Druidic") != None:
            out.append("Druidic")
    except:
        pass
    return out


def _speaker_stem_for_race_match(tag) -> str:
    """Normalize a ``common_speakers`` tag for substring checks against ``character.race``."""
    t = str(tag).lower().strip()
    hard = {
        "elves": "elf",
        "dwarves": "dwarf",
        "gnomes": "gnome",
        "halflings": "halfling",
        "dragonoids": "dragon",
        "goblinoids": "goblin",
        "mind flayers": "illithid",
        "giants": "giant",
        "ogres": "ogre",
        "orcs": "orc",
    }
    if t in hard:
        return hard[t]
    if len(t) > 3 and t.endswith("s") and not t.endswith("ss"):
        return t[:-1]
    return t


def _race_familiarity_bonus(char, target_canonical: str) -> int:
    """0–45 extra familiarity when ``char.race`` matches typical speakers of ``target_canonical`` (PHB-style stems)."""
    if char == None or target_canonical == None:
        return 0
    try:
        r = char.race
    except:
        return 0
    if r == None:
        return 0
    rl = str(r).lower()
    if rl == "":
        return 0
    spec = _LANGUAGES.get(target_canonical)
    if spec == None:
        return 0
    bonus = 0
    for tag in spec["common_speakers"]:
        stem = _speaker_stem_for_race_match(tag)
        if len(stem) < 3:
            continue
        if stem in rl:
            bonus += 22
    extra = [
        ("tiefling", "Infernal", 30),
        ("aasimar", "Celestial", 28),
        ("dragonborn", "Draconic", 32),
        ("githyanki", "Gith", 34),
        ("githzerai", "Gith", 34),
    ]
    for key, lang, amt in extra:
        if target_canonical == lang and key in rl:
            if amt > bonus:
                bonus = amt
    return min(45, bonus)


def _merged_known_languages_for_comprehension(char) -> list:
    """Sheet languages plus class-granted (Thieves' Cant, Druidic), deduped in sheet order then extras.

    **PHB-style default:** if **Common** exists in ``_LANGUAGES`` but is missing from the sheet and grants, it is
    **prepended** anyway. 5e assumes every PC speaks Common; the ``languages`` cvar often omits it. This affects only
    ``language_comprehension_score`` (not ``get_character_languages``).
    """
    sheet = get_character_languages(char)
    grant = _class_granted_languages(char)
    seen = {}
    out = []
    for x in sheet + grant:
        if seen.get(x, False) == False:
            seen[x] = True
            out.append(x)
    if _LANGUAGES.get("Common") != None and seen.get("Common", False) == False:
        out = ["Common"] + out
    return out


def _normalize_communication_method(method) -> str:
    """Normalize caller labels to a value in ``COMMUNICATION_METHODS`` (unknown → ``vocal``)."""
    if method == None:
        return "vocal"
    m = str(method).strip().lower()
    if m == "" or m == "vocal" or m == "spoken" or m == "speech":
        return "vocal"
    if m == "telepathy":
        return "telepathic"
    if m == "telepathic":
        return "telepathic"
    if m == "script" or m == "written" or m == "writing":
        return "script"
    if m == "gestural" or m == "visual" or m == "sign":
        return "gestural"
    return "vocal"


def _language_supports_communication_method(canonical_lang: str, method: str) -> bool:
    """True when the catalog marks ``method`` as a real channel for ``canonical_lang`` (``methods[method]`` is a dict, not ``False``)."""
    spec = _LANGUAGES.get(canonical_lang)
    if spec == None:
        return False
    slot = spec["methods"].get(method, False)
    return slot != False


def _modality_compatibility(canonical_lang: str, method: str) -> int:
    """0–100: channel fit for ``canonical_lang``. When ``methods[method]`` is a dict, returns its ``rarity`` (clamped); else fallbacks + specials."""
    spec = _LANGUAGES[canonical_lang]
    md = spec["methods"]
    bucket = spec["type"]

    slot = md.get(method, False)
    if slot != False:
        try:
            r = int(slot["rarity"])
            if r < 0:
                r = 0
            if r > 100:
                r = 100
            return r
        except:
            return 100

    if canonical_lang == "Psionics" and method == "script":
        return 15

    if method == "vocal" and md.get("gestural") is not False and md.get("vocal") is False:
        return 25

    if method == "gestural" and md.get("gestural") is False and md.get("script") is not False:
        return 55

    if method == "script" and md.get("gestural") is not False and md.get("script") is False:
        return 45

    if method == "telepathic":
        if canonical_lang == "Psionics":
            return 100
        if canonical_lang == "Qualith":
            return 55
        if canonical_lang == "Deep Speech":
            return 75
        if bucket == "standard" or bucket == "uncommon":
            return 40
        return 60

    if method == "vocal":
        if canonical_lang == "Qualith":
            return 25
        if spec["writing_system"] == "telepathy":
            return 35
        return 30

    if method == "script":
        if spec["writing_system"] == "none":
            return 40
        if spec["writing_system"] == "telepathy":
            return 20
        return 30

    if method == "gestural":
        return 30

    return 100


def language_comprehension_score(
    language_name: str,
    char = None,
    communication_method: str = "vocal",
) -> int:
    """0–100 heuristic: how well ``char`` might follow ``language_name`` via ``communication_method`` (``vocal`` default).

    When the character **knows** the target (cvar, class-granted, or **implicit Common** — see
    ``_merged_known_languages_for_comprehension``): returns **100** if that language **supports** the requested
    ``communication_method`` in ``_LANGUAGES`` (the channel is a dict, not ``False``); otherwise **0** (channel not
    used for that language — incomprehensible on that medium).

    When the target is **not** known: combines **directed** similarities from every effective known language, a small
    bonus when several known languages each overlap the target, **race** vs ``common_speakers`` hints, then scales by
    ``_modality_compatibility``.

    Returns ``0`` when there is no effective known language (after grants and implicit **Common**), no similarity or
    race hint applies, and the target is not known. Unknown ``language_name`` → ``0``.
    """
    target = _canonicalize_language_token(language_name)
    if target == None:
        return 0

    method = _normalize_communication_method(communication_method)
    char = _require_character(char, "language comprehension")
    heritage = _race_familiarity_bonus(char, target)
    known = _merged_known_languages_for_comprehension(char)
    if len(known) == 0 and heritage == 0:
        return 0

    if _character_knows_language(target, known):
        if _language_supports_communication_method(target, method):
            return 100
        return 0

    modality_fac = _modality_compatibility(target, method)
    sims = []
    for _k in known:
        if _k == target:
            continue
        sims.append(_get_similarity(_k, target, method))
    mx = 0
    for s in sims:
        if s > mx:
            mx = s
    total = 0
    for s in sims:
        total += s
    crowd = 0
    if len(sims) > 0 and total > mx:
        crowd = int((total - mx) * 0.14)
    raw = mx + crowd + heritage
    if raw > 100:
        raw = 100
    if mx == 0 and crowd == 0 and heritage == 0:
        return 0
    partial = int(raw * 55 / 100)
    return int(partial * modality_fac / 100)
