cfg_fixture = {
    "subsystems": {
        "crafting": {
            "enabled": True,
            "commands": {"craft": True, "brew": True, "enchant": True, "scribe": True},
            "config": {
                "catalogues": {
                    "items": "engine:catalogues/items",
                    "potions": "engine:catalogues/potions",
                    "spells": "engine:catalogues/spells",
                    "magic_items": "engine:catalogues/magic_items",
                    "recipes": None,
                },
            },
            "command_config": {"scribe": {"rules_version": "2024"}},
        },
    },
    "policies": {
        "crafting": {"resources": {"downtime": "manual", "gold": "manual", "spell_slot": "manual"}},
        "inventory": {"item_handling": {"mode": "manual"}},
    },
}
args = argparse("-l 5 -sb 3 -dc 11")
scribe_ch = {"spellbook": {"spells": ["Fireball"]}}
plan = crafting.build_plan(cfg_fixture, "scribe", "Fireball", args, scribe_ch)
return plan["ok"] == True and plan["name"] == "Scroll of Fireball (Lv. 5 | SB +3 | DC 11)"
