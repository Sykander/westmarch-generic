cfg_fixture = {
    "subsystems": {
        "crafting": {
            "enabled": True,
            "commands": {"brew": True},
            "config": {
                "catalogues": {
                    "potions": "engine:catalogues/potions",
                    "recipes": [
                        {
                            "id": "heal",
                            "name": "Potion of Healing",
                            "kind": "brew",
                            "workdays": 2,
                            "gold": 10,
                            "consumed": [{"item": "Arnica", "qty": 2}],
                        },
                    ],
                },
            },
        },
    },
    "policies": {
        "crafting": {"resources": {"downtime": "manual", "gold": "manual", "materials": "manual"}},
        "inventory": {"item_handling": {"mode": "manual"}},
    },
}
plan = crafting.build_plan(cfg_fixture, "brew", "Potion of Healing", None, character())
return plan["ok"] == True and plan["workdays"] == 2 and plan["gold"] == 10 and len(plan["consumed"]) == 1
