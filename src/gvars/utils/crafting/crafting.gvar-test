name: output policy reads inventory bag config

cfg_fixture = {
    "subsystems": {
        "crafting": {
            "config": {
                "checks": {"scribe": {"mode": "manual", "skill": "arcana", "dc": 15}},
                "tool_policy": {
                    "scribe": {
                        "mode": "manual",
                        "tools": ["Calligrapher's Supplies"],
                        "require_proficiency": True,
                    },
                },
            },
        },
    },
}
check = crafting.check_policy(cfg_fixture, "scribe")
tool = crafting.tool_policy(cfg_fixture, "scribe")
return check["mode"] == "manual" and check["dc"] == 15 and tool["mode"] == "manual" and tool["tools"][0] == "Calligrapher's Supplies"
