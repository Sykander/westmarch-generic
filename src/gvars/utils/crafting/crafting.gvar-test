args = argparse("-l 5 -ability cha -score 12 -pb 2")
sb, dc, stats_error = crafting.scroll_stats_2024({"spellbook": {"sab": 6, "dc": 14}}, args)
return stats_error == None and sb == 6 and dc == 14
