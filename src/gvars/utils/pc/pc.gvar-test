ch = character()
cfg_fixture = {"subsystems": {"downtime": {"config": {"mode": "tracked", "max_workdays": None}}}}
balance = pc.get_downtime(ch, cfg_fixture)
tracking = load_json(ch.cvars["wg_downtime_tracking"])
return balance == 0 and ch.cvars["wg_downtime"] == "0" and tracking.registered_at > 0 and tracking.accrual_epoch <= tracking.registered_at
---
True
---
name: tracked downtime initializes registration metadata

ch = character()
now = int(time())
epoch = now - (24 * 60 * 60) + 100
ch.set_cvar("wg_downtime", "0")
ch.set_cvar("wg_downtime_tracking", dump_json({"registered_at": epoch + 1, "accrual_epoch": epoch, "credited_days": 0}))
cfg_fixture = {"subsystems": {"downtime": {"config": {"mode": "tracked", "max_workdays": None}}}}
first = pc.get_downtime(ch, cfg_fixture)
tracking = load_json(ch.cvars["wg_downtime_tracking"])
next_at = pc.downtime_next_at(ch, cfg_fixture)
return first == 0 and tracking.accrual_epoch == epoch and tracking.credited_days == 0 and next_at == epoch + (24 * 60 * 60)
---
True
