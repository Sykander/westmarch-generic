True
---
name: modify_downtime grants workdays
vars:
  cvars:
    wg_downtime: "2"

cfg_fixture = {"policies": {"downtime": {"mode": "tracked", "max_workdays": None}}}
ok, msg = pc.modify_downtime(character(), -2, cfg_fixture)
return ok and pc.get_downtime(character(), cfg_fixture) == 3 and "spent **2**" in msg
---
True
---
name: modify_downtime spends workdays
vars:
  cvars:
    wg_downtime: "5"

cfg_fixture = {"policies": {"downtime": {"mode": "tracked", "max_workdays": None}}}
ok, msg = pc.modify_downtime(character(), -2, cfg_fixture)
return not ok and pc.get_downtime(character(), cfg_fixture) == 1 and "only has **1**" in msg
---
True
---
name: modify_downtime rejects overspend
vars:
  cvars:
    wg_downtime: "1"

cfg_fixture = {"policies": {"downtime": {"mode": "tracked", "max_workdays": 5}}}
ok, msg = pc.modify_downtime(character(), 2, cfg_fixture)
return not ok and pc.get_downtime(character(), cfg_fixture) == 4 and "capped" in msg
