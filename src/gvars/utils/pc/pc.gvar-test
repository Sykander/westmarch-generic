    wg_downtime_start: "10"
    wg_downtime_used: "3"

ch = character()
now = int(time())
epoch = now - (2 * 24 * 60 * 60) - 60
ch.set_cvar("wg_downtime", "3")
ch.set_cvar("wg_downtime_tracking", dump_json({"registered_at": epoch + 60, "accrual_epoch": epoch, "credited_days": 0}))
cfg_fixture = {"subsystems": {"downtime": {"config": {"mode": "tracked", "max_workdays": None}}}}
return pc.get_downtime(ch, cfg_fixture) == 5
