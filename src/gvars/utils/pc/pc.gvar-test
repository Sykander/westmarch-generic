cfg_fixture = {
    "subsystems": {
        "exploration": {
            "enabled": True,
            "commands": {"enc": True},
            "command_config": {"enc": {"cooldown_seconds": 120}},
        },
    },
    "policies": {"exploration": {"enforce_cooldowns": True}},
}
allowed, remaining = pc.check_cooldown(character(), "enc", cfg_fixture)
return allowed == False and remaining > 0
