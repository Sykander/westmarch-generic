name: westmarch loot skill mapping follows monster type

session = {"creature": "Wolf", "items": []}
return "Wolf" in loot.format_session(session, {}) and "No lootables" in loot.format_session(session, {})
---
True
---
name: format_session handles empty active session

session = {"creature": "Wolf", "items": []}
return "`?loot clear`" in loot.format_session(session, {}, "?", "loot") and "`?loot <creature>`" in loot.help_text("?", "loot")
---
True
---
name: loot help and empty sessions use the provided command prefix

session = {
    "creature": "Wolf",
    "items": [
        {"id": "ration", "name": "Wolf Ration", "skill": "survival", "dc": 10, "kind": "item", "amount": 3},
    ],
}
cfg = {"subsystems": {"exploration": {"config": {"show_check_dcs": {"loot": False}}}}}
text = loot.format_session(session, cfg)
return "3x Wolf Ration" in text and "Survival check" in text and "DC" not in text
---
True
---
name: format_session hides loot dcs when configured

session = {
    "creature": "Goblin",
    "items": [
        {"id": "coins", "name": "Coins", "skill": "sleightOfHand", "dc": 10, "kind": "gold", "amount": 12},
    ],
}
cfg = {"subsystems": {"exploration": {"config": {"show_check_dcs": {"loot": False}}}}}
text = loot.format_session(session, cfg)
return "Coins" in text and "Sleight of Hand check" in text and "12" not in text
