monster = {"name": "Wolf", "cr": 0.25, "type_str": "Beast", "size": "M"}
categories = loot.possible_loot_categories(monster)
return categories == ["trophy", "ration"] and loot.loot_skill_for_type("Beast") == "nature"
---
True
---
name: beast loot categories allow trophy and ration

monster = {"name": "Goblin", "cr": 0.25, "type_str": "Humanoid", "size": "S"}
categories = loot.possible_loot_categories(monster)
return categories == ["coins"] and "trophy" not in categories and "ration" not in categories
