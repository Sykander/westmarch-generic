a = display.get_display()
b = display.get_display()
return a == b
---
True
---
name: get_display cache returns same callable

get_embed = display.get_display()
return get_embed(desc="hello")
---
re:-title Westmarch
---
name: default branding produces embed with westmarch title

get_embed = display.get_display()
return "-t " in get_embed(desc="hello")
---
False
---
name: default non-error embed has no timeout

get_embed = display.get_display()
return "-t 60" in get_embed(desc="hello", error=True)
---
True
---
name: default error embed times out after sixty seconds

get_embed = display.get_display()
return "-t " in get_embed(desc="hello", error=True)
---
False
---
name: configured error embeds can stay in chat
vars:
  svars:
    westmarch_config: "22226666-6666-6666-6666-666666666666"
  gvars:
    22226666-6666-6666-6666-666666666666: |
      policies = {
          "display": {"error_embeds": {"auto_delete": False}},
      }

get_embed = display.get_display()
return "-t 5" in get_embed(desc="hello", error=True)
---
True
---
name: configured error embed timeout is used
vars:
  svars:
    westmarch_config: "22227777-7777-7777-7777-777777777777"
  gvars:
    22227777-7777-7777-7777-777777777777: |
      policies = {
          "display": {"error_embeds": {"timeout_seconds": 5}},
      }

get_embed = display.get_display("hunt")
return get_embed(desc="hello")
---
re:-title Hunt
---
name: command override produces command title

get_embed = display.get_display()
return get_embed(desc="hello")
---
re:-thumb https://sykander.github.io/westmarch-generic/westmarch-assets/brand/logo.png
---
name: default branding uses deployed logo thumbnail

get_embed = display.get_display()
return "westmarch show" not in get_embed(desc="hello")
---
True
---
name: default helpful footer does not suggest admin-only show command
vars:
  svars:
    westmarch_config: "22228888-8888-8888-8888-888888888888"
  gvars:
    22228888-8888-8888-8888-888888888888: |
      policies = {
          "display": {"footer_behaviour": "helpful_tips"},
      }

get_embed = display.get_display()
return get_embed(desc="hello")
---
re:My Test World
---
name: base display name becomes embed title
vars:
  svars:
    westmarch_config: "22222222-2222-2222-2222-222222222222"
  gvars:
    22222222-2222-2222-2222-222222222222: |
      display = {
          "name": "My Test World",
      }

get_embed = display.get_display()
return get_embed(desc="hello")
---
re:Footer A
---
name: fixed footer list resolves footer text
vars:
  svars:
    westmarch_config: "22223333-3333-3333-3333-333333333333"
  gvars:
    22223333-3333-3333-3333-333333333333: |
      display = {
          "name": "My Test World",
          "footer": ["Footer A"],
      }
      policies = {
          "display": {"footer_behaviour": "string"},
      }

get_embed = display.get_display()
return get_embed(desc="hello")
---
re:-thumb https://example.test/logo.png
---
name: base display logo overrides default thumbnail
vars:
  svars:
    westmarch_config: "22224444-4444-4444-4444-444444444444"
  gvars:
    22224444-4444-4444-4444-444444444444: |
      display = {
          "name": "My Test World",
          "logo": "https://example.test/logo.png",
      }

get_embed = display.get_display()
return get_embed(desc="hello")
---
re:-thumb https://example.test/pc.png
---
name: command thumbnail can use selected character image
vars:
  svars:
    westmarch_config: "22225555-5555-5555-5555-555555555555"
  gvars:
    22225555-5555-5555-5555-555555555555: |
      display = {
          "logo": "https://example.test/logo.png",
      }
      policies = {
          "display": {"command_thumbnail": "character"},
      }
character:
  image: "https://example.test/pc.png"
