name: quests formats empty active list

ok, msg = quests.append_entry(character(), {}, "Find the Scout", "Spoke to the innkeeper.")
journal = quests.load_journal(character())
matches = quests.find_quests(journal, "scout")
return ok and len(matches) == 1 and "Find the Scout" in quests.format_quest(matches[0])
