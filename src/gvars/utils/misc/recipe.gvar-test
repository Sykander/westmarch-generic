cfg_fixture = {
    "subsystems": {
        "crafting": {
            "config": {
                "catalogues": {
                    "recipes": "engine:configs/recipes/recipes_list",
                },
            },
        },
    },
}
matches = recipe.name_matches(cfg_fixture, "Potion of Healing", "brew")
return len(matches) > 0 and "Potion of Healing" in matches
