cfg_fixture = {
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
        "paths": [
            {
                "from": "river_town",
                "to": "oakwood",
                "steps": [{"type": "encounter", "biome": "forest"}],
                "requirements": {"transport": "walk"},
            },
            {
                "from": "river_town",
                "to": "oakwood",
                "steps": [{"type": "proceed", "description": "Ride the old road."}],
                "requirements": {"transport": "horse"},
            },
        ],
    },
}
walk_edges = paths.get_edges_from(cfg_fixture, "river_town", "walk")
horse_edges = paths.get_edges_from(cfg_fixture, "river_town", "horse")
return len(walk_edges) == 1 and len(horse_edges) == 1 and paths.get_path_steps(horse_edges[0], "horse")[0]["description"] == "Ride the old road."
---
True
---
name: get_edges_from filters transport requirements

cfg_fixture = {
    "world_data": {
        "transport": {
            "horse": {"name": "Horse or mount", "aliases": ["riding_horse", "warhorse", "pony"]},
        },
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
        "paths": [
            {
                "from": "river_town",
                "to": "oakwood",
                "steps": [{"type": "proceed", "description": "Follow the horse road."}],
                "requirements": {"transport": "riding_horse"},
            },
        ],
    },
}
edges = paths.get_edges_from(cfg_fixture, "river_town", "horse")
return len(edges) == 1 and paths.get_path_steps(edges[0], "horse")[0]["description"] == "Follow the horse road."
---
True
---
name: get_edges_from matches route requirements through configured aliases

path = {"from": "river_town", "to": "oakwood", "encs": ["forest", "forest"], "horse": ["road"]}
walk_steps = paths.get_path_steps(path, "walk")
horse_steps = paths.get_path_steps(path, "horse")
return len(walk_steps) == 2 and len(horse_steps) == 1 and horse_steps[0]["biome"] == "road"
---
True
---
name: get_path_steps supports westmarch encs and horse shorthand

path = {"from": "river_town", "to": "oakwood", "gold": 50}
steps = paths.get_path_steps(path)
return steps[0]["type"] == "cost" and steps[0]["gold"] == 50 and paths.get_path_cost(path) == 2
---
True
---
name: gold shorthand becomes cost step

cfg_fixture = {
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
    },
}
path = {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]}
text = paths.display_path(path, cfg_fixture, "detailed", "walk", "!")
return "River Town" in text and "Oakwood Forest" in text and "!enc forest" in text
---
True
---
name: display_path shows linked location names and encounter steps

path = {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "activity": "forage", "biome": "forest"}]}
text = paths.display_path(path, {}, "detailed", "walk", "!")
return "!forage forest" in text
---
True
---
name: display_path respects activity-specific encounter steps

cfg_fixture = {
    "subsystems": {"exploration": {"config": {"enc_biome_source": "location"}}},
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
    },
}
path = {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": ""}]}
text = paths.display_path(path, cfg_fixture, "detailed", "walk", "!")
return "Run `!enc`" in text and "Run `!enc `" not in text and "no biome" not in text
---
True
---
name: display_path omits blank biome argument when location inference is configured

cfg_fixture = {
    "subsystems": {"exploration": {"config": {"enc_biome_source": "argument"}}},
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
    },
}
path = {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": ""}]}
text = paths.display_path(path, cfg_fixture, "detailed", "walk", "!")
return "Run `!enc`" in text and "Encounter step has no biome" in text
---
True
---
name: display_path warns when manual biome mode has empty encounter step

cfg_fixture = {
    "subsystems": {"travel": {"config": {"transport_icons": {"walk": "W", "horse": "H"}}}},
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
    },
}
path = {"from": "river_town", "to": "oakwood", "steps": [{"type": "proceed", "description": "Follow the road."}]}
text = paths.display_path(path, cfg_fixture, "detailed", "horse", "!")
return "* H Follow the road." in text
