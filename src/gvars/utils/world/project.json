{
  "name": "avrae-gvar-utils-world",
  "projectType": "library",
  "sourceRoot": "src/gvars/utils/world",
  "tags": ["scope:avrae", "type:gvar-utils"],
  "implicitDependencies": [
    "avrae-sourcemaps",
    "avrae-gvar-utils-core",
    "avrae-gvar-utils-config",
    "avrae-gvar-utils-encounters"
  ],
  "targets": {
    "test": {
      "executor": "nx:noop",
      "cache": true,
      "dependsOn": [
        "test-biomes",
        "test-journeys",
        "test-location-encounters",
        "test-locations",
        "test-paths"
      ],
      "outputs": []
    },
    "test-biomes": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": [
        "avraeGvarUtilBase",
        "{workspaceRoot}/src/gvars/utils/config/**/*",
        "{workspaceRoot}/src/gvars/utils/encounters/**/*"
      ],
      "outputs": [],
      "options": {
        "command": "avrae-ls --log-level INFO --run-tests src/gvars/utils/world/biomes.gvar-test"
      }
    },
    "test-journeys": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
