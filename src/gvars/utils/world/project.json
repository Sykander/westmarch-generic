      ],
      "outputs": [],
      "options": {
        "command": "avrae-ls --log-level INFO --run-tests src/gvars/utils/world/location_encounters.gvar-test"
      }
    },
    "test-locations": {
      "executor": "nx:run-commands",
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": [
        "avraeGvarUtilBase",
        "{workspaceRoot}/src/gvars/utils/config/**/*",
        "{workspaceRoot}/src/gvars/utils/encounters/**/*"
      ],
      "outputs": [],
