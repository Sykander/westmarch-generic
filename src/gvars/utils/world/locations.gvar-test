name: search_locations returns ambiguous partial matches

cfg_fixture = {
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
    },
}
matches = locations.search_locations(cfg_fixture, "Oakwood Forest")
return len(matches) == 1 and matches[0]["id"] == "oakwood"
---
True
---
name: search_locations matches display name

cfg_fixture = {
    "world_data": {
        "locations": {
            "oakwood": {
                "name": "Oakwood Forest",
                "description": "Tall trees.",
                "commands": {"enc": ["forest"], "forage": ["forest"]},
            },
        },
    },
}
loc = locations.get_location(cfg_fixture, "oakwood")
text = locations.display_location(loc, "full", character(), True, 2)
return "Oakwood Forest" in text and "Tall trees." in text and "forage" in text and "2" in text
---
True
---
name: display_location includes description activities and visits
