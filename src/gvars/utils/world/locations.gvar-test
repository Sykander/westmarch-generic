cfg_fixture = {
    "world_data": {
        "default_location": "river_town",
        "locations": {
            "river_town": {"name": "River Town", "description": "A busy quay."},
            "oakwood": {"name": "Oakwood Forest"},
            "oakwood_east": {"name": "Oakwood East Trail"},
        },
    },
}
loc = locations.get_location(cfg_fixture, "river_town")
return loc["id"] == "river_town" and loc["name"] == "River Town"
---
True
---
name: get_location injects dict key id

cfg_fixture = {
    "world_data": {
        "default_location": "river_town",
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
            "oakwood_east": {"name": "Oakwood East Trail"},
        },
    },
}
matches = locations.search_locations(cfg_fixture, "oak")
return len(matches) == 2
---
True
---
name: search_locations returns ambiguous partial matches

cfg_fixture = {
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
    },
}
matches = locations.search_locations(cfg_fixture, "Oakwood Forest")
return len(matches) == 1 and matches[0]["id"] == "oakwood"
---
True
---
name: search_locations matches display name

cfg_fixture = {
    "world_data": {
        "locations": {
            "oakwood": {
                "name": "Oakwood Forest",
                "description": "Tall trees.",
                "commands": {"enc": ["forest"], "forage": ["forest"], "job": True, "buy": True},
            },
        },
    },
}
loc = locations.get_location(cfg_fixture, "oakwood")
text = locations.display_location(loc, "full", character(), True, 2)
return "Oakwood Forest" in text and "Tall trees." in text and "forage" in text and "buy" in text and "2" in text
---
True
---
name: display_location includes description activities and visits

cfg_fixture = {
    "subsystems": {
        "economy": {
            "config": {
                "jobs": [
                    {"id": "guard", "name": "Caravan Guard", "skills": ["athletics", "perception"]},
                ],
            },
        },
    },
    "world_data": {
        "locations": {
            "river_town": {
                "name": "River Town",
                "commands": {"job": True},
            },
        },
    },
}
loc = locations.get_location(cfg_fixture, "river_town")
text = locations.display_location(loc, "full", character(), True, 1, cfg_fixture)
return "First visit." in text and "Jobs here" in text and "Caravan Guard" in text and "Jobs" in text
---
True
---
name: display_location shows configured jobs when boolean job command is enabled

cfg_fixture = {
    "subsystems": {
        "economy": {
            "config": {
                "jobs": [
                    {"id": "guard", "name": "Caravan Guard", "skills": ["athletics"]},
                ],
            },
        },
    },
    "world_data": {
        "locations": {
            "river_town": {
                "name": "River Town",
                "commands": {"job": {"name": "Inline Job"}},
            },
        },
    },
}
loc = locations.get_location(cfg_fixture, "river_town")
return not locations.location_has_job(loc) and len(locations.jobs_for_location(cfg_fixture, loc)) == 0
---
True
---
name: location job command remains boolean only

trade_loc = {"id": "river_town", "name": "River Town", "commands": {"buy": True}}
quiet_loc = {"id": "quiet_road", "name": "Quiet Road", "commands": {"enc": ["road"]}}
return locations.location_has_trade(trade_loc) == True and locations.location_has_trade(quiet_loc) == False
---
True
---
name: location trade command remains boolean availability

cfg_fixture = {
    "world_data": {
        "locations_gvar_id": "eeee1111-1111-1111-1111-111111111111",
        "locations": {"inline_camp": {"name": "Inline Camp"}},
    },
}
river = locations.get_location(cfg_fixture, "river_town")
ids = locations.list_location_ids(cfg_fixture)
return river["name"] == "River Town" and "river_town" in ids and "inline_camp" in ids
---
True
---
name: locations can load from world_data locations_gvar_id with inline additions
vars:
  gvars:
    eeee1111-1111-1111-1111-111111111111: |
      {"river_town":{"name":"River Town"}}
