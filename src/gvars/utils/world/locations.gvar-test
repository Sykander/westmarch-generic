cfg_fixture = {
    "world_data": {
        "default_location": "river_town",
        "locations": {
            "river_town": {"name": "River Town", "description": "A busy quay."},
            "oakwood": {"name": "Oakwood Forest"},
            "oakwood_east": {"name": "Oakwood East Trail"},
        },
    },
}
loc = locations.get_location(cfg_fixture, "river_town")
return loc["id"] == "river_town" and loc["name"] == "River Town"
---
True
---
name: get_location injects dict key id

cfg_fixture = {
    "world_data": {
        "default_location": "river_town",
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
            "oakwood_east": {"name": "Oakwood East Trail"},
        },
    },
}
matches = locations.search_locations(cfg_fixture, "oak")
return len(matches) == 2
---
True
