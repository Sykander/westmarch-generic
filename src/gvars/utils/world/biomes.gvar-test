    eeee5555-5555-5555-5555-555555555555: |
      [[["enc.gather", "forage.gather"], "flavour", "Shared Berries", "", "gather"]]

entries = biomes.get_pool_entries("forest", "forage", "gather")
combat_entries = biomes.get_pool_entries("forest", "forage", "combat")
return len(entries) == 1 and entries[0]["name"] == "Any Gather" and len(combat_entries) == 0
