name: get_pool_entries loads inline biome gvar
vars:
  svars:
    westmarch_config: "eeee3333-3333-3333-3333-333333333333"
  gvars:
    eeee3333-3333-3333-3333-333333333333: |
      subsystems = {
          "exploration": {"enabled": True, "commands": {"enc": True}},
      }
      world_data = {
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      pools = {
          "enc": {
              "gather": [{"kind": "gather", "name": "Berries in the Wild"}],
          },
      }

cfg_fixture = {
    "subsystems": {
        "exploration": {
            "enabled": True,
            "commands": {"enc": True},
            "config": {"enc_biome_source": "auto"},
        },
        "travel": {
            "enabled": True,
            "commands": {"location": True},
        },
    },
    "world_data": {
        "biomes": {"forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"}},
        "locations": {"oakwood": {"name": "Oakwood", "commands": {"enc": ["forest"]}}},
    },
}
return biomes.uses_location_mode(cfg_fixture)
