      subsystems = {
          "exploration": {"enabled": True, "commands": {"enc": True}},
      }
      world_data = {
          "biomes": {
              "forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"},
          },
      }
    eeee5555-5555-5555-5555-555555555555: |
      [[["enc.gather"], "flavour", "Berries in the Wild", "", "gather"]]

entries = biomes.get_pool_entries("forest", "forage", "gather")
return len(entries) == 1 and entries[0]["name"] == "Shared Berries"
