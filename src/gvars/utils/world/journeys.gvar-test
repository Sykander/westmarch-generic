vars:
  svars:
    westmarch_config: "eeee3334-3334-3334-3334-333333333334"
  gvars:
    eeee3334-3334-3334-3334-333333333334: |
      subsystems = {
          "exploration": {"enabled": True, "commands": {"enc": True}},
          "travel": {"enabled": True, "commands": {"location": True}},
      }
      world_data = {
          "default_location": "oakwood",
          "biomes": {"forest": {"gvar_id": "eeee5555-5555-5555-5555-555555555555"}},
          "locations": {
              "oakwood": {"name": "Oakwood", "commands": {"enc": ["forest"]}},
          },
      }

return journeys.get_location_id(character())
---
oakwood
---
name: get_location_id reads wg_location cvar
vars:
  cvars:
    wg_location: "Oakwood"

cfg_fixture = {
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
            "oakwood_east": {"name": "Oakwood East Trail"},
        },
        "paths": [
            {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]},
            {"from": "oakwood", "to": "oakwood_east", "steps": [{"type": "encounter", "biome": "forest"}]},
            {"from": "river_town", "to": "oakwood_east", "steps": [{"type": "encounter", "biome": "road"}, {"type": "encounter", "biome": "road"}, {"type": "encounter", "biome": "road"}]},
        ],
    },
}
found, legs = journeys.find_journey(cfg_fixture, "river_town", "oakwood_east")
return found and len(legs) == 2 and legs[0]["to"] == "oakwood"
---
True
---
name: find_journey chooses cheaper multi-leg path

cfg_fixture = {
    "world_data": {
        "transport": {
            "walk": {"name": "Walking", "default": True, "aliases": ["walking"]},
            "horse": {"name": "Horse or mount", "aliases": ["riding_horse", "warhorse", "pony"]},
        },
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
        "paths": [
            {
                "from": "river_town",
                "to": "oakwood",
                "steps": [{"type": "proceed", "description": "Ride the old road."}],
                "requirements": {"transport": "horse"},
            },
        ],
    },
}
matches = journeys.search_transport(cfg_fixture, "riding_horse")
found, legs = journeys.find_journey(cfg_fixture, "river_town", "oakwood", transport_id="riding_horse")
journey = journeys.build_journey(cfg_fixture, "river_town", "oakwood", legs, transport_id="riding_horse")
return len(matches) == 1 and journeys.get_transport_id(matches[0]) == "horse" and found and journey["transport"] == "horse"
---
True
---
name: specific transport aliases resolve to canonical journey categories

cfg_fixture = {
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
        "paths": [
            {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]},
        ],
    },
}
found, legs = journeys.find_journey(cfg_fixture, "river_town", "oakwood")
journey = journeys.build_journey(cfg_fixture, "river_town", "oakwood", legs)
text = journeys.display_journey(cfg_fixture, journey, "detailed", prefix="!")
return found and "River Town" in text and "Oakwood Forest" in text and "!enc forest" in text
---
True
---
name: display_journey includes route names and steps

cfg_fixture = {
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
        "paths": [
            {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]},
        ],
    },
}
journey = journeys.build_journey(cfg_fixture, "river_town", "oakwood", [{"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}]}])
journeys.set_journey(character(), journey)
progressed, messages = journeys.next_step(character(), cfg_fixture)
loc_id = journeys.get_location_id(character(), cfg_fixture)
return progressed and loc_id == "oakwood" and "Arrived" in " ".join(messages)
---
True
---
name: next_step arrives and updates location cvar

cfg_fixture = {
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
        "paths": [
            {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}, {"type": "encounter", "biome": "road"}]},
        ],
    },
}
journey = journeys.build_journey(cfg_fixture, "river_town", "oakwood", [{"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "forest"}, {"type": "encounter", "biome": "road"}]}])
journeys.set_journey(character(), journey)
advanced, messages = journeys.complete_activity_step(character(), cfg_fixture, "enc", "forest")
stored = journeys.get_journey(character())
return advanced and stored["path_index"] == 0 and stored["step_index"] == 1 and "Journey step completed." in " ".join(messages)
---
True
---
name: complete_activity_step advances matching encounter step

cfg_fixture = {
    "world_data": {
        "locations": {
            "river_town": {"name": "River Town"},
            "oakwood": {"name": "Oakwood Forest"},
        },
        "paths": [
            {"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "road"}]},
        ],
    },
}
journey = journeys.build_journey(cfg_fixture, "river_town", "oakwood", [{"from": "river_town", "to": "oakwood", "steps": [{"type": "encounter", "biome": "road"}]}])
journeys.set_journey(character(), journey)
advanced, messages = journeys.complete_activity_step(character(), cfg_fixture, "enc", "forest")
stored = journeys.get_journey(character())
return not advanced and len(messages) == 0 and stored["path_index"] == 0 and stored["step_index"] == 0
