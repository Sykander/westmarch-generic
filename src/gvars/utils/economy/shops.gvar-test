name: shops scales gp and wallet prices

cfg_fixture = {
    "shops": {
        "general": {
            "id": "general",
            "name": "General Store",
            "location_id": "oakwood",
            "stock": [{"item": "Rope, Hemp (50 ft)", "price": {"gold": 1}}],
        },
        "docks": {
            "id": "docks",
            "name": "Dock Market",
            "location_id": "harbor",
            "stock": [{"item": "Rope, Hemp (50 ft)", "price": {"gold": 1}}],
        },
    },
}
return len(shops.list_shops(cfg_fixture, "oakwood")) == 1 and shops.shop_name(shops.list_shops(cfg_fixture, "oakwood")[0]) == "General Store"
