stock, item_matches, item_error = shops.find_stock_item(shop, "herbalism", cfg_fixture)
price = shops.price_for_buy(shop, stock, 1, cfg_fixture)
return stock != None and item_error == None and shops.stock_item_name(stock) == "Herbalism Kit" and price["gold"] == 5
