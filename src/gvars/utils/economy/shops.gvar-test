name: shops resolves shop and validates stock item against catalogue

cfg_fixture = {
    "currencies": {"shards": {"name": "Arcane Shard", "plural": "Arcane Shards", "symbol": "◇"}},
    "shops": {
        "general": {
            "id": "general",
            "name": "General Store",
            "stock": [
                {"item": "Rope, Hemp (50 ft)", "price": {"gold": 2, "shards": 1}},
            ],
        },
    },
}
shop, matches, error = shops.find_shop(cfg_fixture, "general")
stock, item_matches, item_error = shops.find_stock_item(shop, "hemp", cfg_fixture)
price = shops.price_for_buy(shop, stock, 3, cfg_fixture)
return price["gold"] == 6 and price["shards"] == 3 and "Arcane Shards" in shops.format_price(cfg_fixture, price)
