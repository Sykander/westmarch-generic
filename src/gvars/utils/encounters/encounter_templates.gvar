def raw(args):
    """Return a literal encounter dict. Args: encounter_dict"""
    value = _args(args, 0)
    if value != None and dicts.is_dict(value):
        return value
    return None


def _custom_template(config_override, key):
    templates = _read_field(config_override, "encounter_templates")
    fn = _template_from_map(templates, key)
    if fn != None:
        return fn
    for addr in _external_template_gvars(config_override):
        mod = _load_template_gvar(addr)
        if mod == None:
            continue
        fn = _template_from_map(_read_field(mod, "encounter_templates"), key)
        if fn != None:
            return fn
    return None


def _template_from_map(templates, key):
    if templates == None or not dicts.is_dict(templates):
        return None
    direct = _read_field(templates, key)
    if direct != None:
        return direct
    for name in templates:
        if str(name).strip().lower() == key:
            return templates[name]
    return None


def _append_template_gvar_ids(target, value):
    if value == None:
        return
    if lists.is_list(value):
        for item in value:
            _append_template_gvar_ids(target, item)
        return
    if dicts.is_dict(value):
        direct = _read_field(value, "gvar_id")
        if direct != None:
            _append_template_gvar_ids(target, direct)
        for key in ["gvar_ids", "gvars"]:
            many = _read_field(value, key)
            if many != None:
                _append_template_gvar_ids(target, many)
        return
    text = str(value).strip()
    if text != "":
        target.append(text)


def _external_template_gvars(config_override):
    ids = []
    _append_template_gvar_ids(ids, _read_field(config_override, "encounter_templates_gvar_id"))
    ext = _read_field(config_override, "extensions")
    _append_template_gvar_ids(ids, _read_field(ext, "encounter_templates"))
    return ids


def _load_template_gvar(addr):
    if addr == None or str(addr).strip() == "":
        return None
    addr = str(addr).strip()
    try:
        using(_owner_templates=addr)
        return _owner_templates
    except:
        return None


def _expand_custom(template_name, args, config_override=None):
    key = _text(template_name).strip().lower()
    fn = _custom_template(config_override, key)
    if fn == None:
        return None
    try:
        enc = fn(args)
        if enc != None and dicts.is_dict(enc):
            return enc
    except:
        return None
    return None


def expand(template_name, args, config_override=None):
    """Return an encounter dict from a template name + arg list."""
    key = _text(template_name).strip().lower()
    if args == None:
        args = []
    custom = _expand_custom(template_name, args, config_override)
    if custom != None:
        return custom
    if key in ["gather_item", "gather"]:
        return gather_item(args)
    if key in ["skill_check", "check"]:
        return skill_check(args)
    if key in ["saving_throw", "save"]:
        return saving_throw(args)
    if key in ["flavour", "flavor", "static", "story"]:
        return story(args)
    if key in ["combat"]:
        return combat_template(args)
    if key in ["damage_combat", "combat_damage", "hazard_combat"]:
        return damage_combat(args)
    if key in ["ambush"]:
        return ambush(args)
    if key in ["quest", "hook"]:
        return quest(args)
    if key in ["gold", "gp"]:
        return gold(args)
    if key in ["healing", "heal"]:
        return healing(args)
    if key in ["healing_check", "heal_check"]:
        return healing_check(args)
    if key in ["damage", "hazard"]:
        return damage(args)
    if key in ["raw", "encounter"]:
        return raw(args)
    return None


def expand_row(row, config_override=None):
    """Expand [pool_tags|null, template_name, *args] to an encounter dict."""
    if row == None or not lists.is_list(row) or len(row) < 2:
        return None
    args = []
    for index in range(2, len(row)):
        args.append(row[index])
    return expand(row[1], args, config_override)
