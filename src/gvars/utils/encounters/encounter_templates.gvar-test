def custom_scene(args):
    name = args[0]
    return {"kind": "quest", "name": name, "description": "Custom from config"}

cfg_fixture = {"encounter_templates": {"custom_scene": custom_scene}}
enc = encounter_templates.expand_row([["enc.quest"], "custom_scene", "Lost marker"], cfg_fixture)
return enc["kind"] == "quest" and enc["name"] == "Lost marker" and enc["description"] == "Custom from config"
---
True
---
name: config custom encounter template expands compact rows
