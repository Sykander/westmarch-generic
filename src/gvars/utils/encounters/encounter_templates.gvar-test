name: config custom encounter template expands compact rows with args helper

cfg_fixture = {"extensions": {"encounter_templates": "eeee7777-7777-7777-7777-777777777777"}}
enc = encounter_templates.expand_row([["enc.quest"], "external_scene", "Old gate"], cfg_fixture)
return enc["name"] == "Old gate" and enc["description"] == "External template"
---
True
---
name: external custom encounter template gvar expands compact rows
vars:
  gvars:
    eeee7777-7777-7777-7777-777777777777: |
      using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
      using(templates = env.gvars.encounter_templates)
      def external_scene(args):
          title = templates.arg(args, 0, "External scene")
          return {"name": title, "description": "External template"}
      encounter_templates = {
          "external_scene": external_scene,
      }

return encounter_templates.arg(["first"], 0, "fallback") == "first" and encounter_templates.arg([], 0, "fallback") == "fallback"
---
True
---
name: public arg helper reads optional row values
