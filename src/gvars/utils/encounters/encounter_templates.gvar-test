def custom_scene(args):
    name = encounter_templates.arg(args, 0)
    description = encounter_templates.arg(args, 1, "Custom from config")
    return {"name": name, "description": description}

cfg_fixture = {"encounter_templates": {"custom_scene": custom_scene}}
enc = encounter_templates.expand_row([["enc.quest"], "custom_scene", "Lost marker"], cfg_fixture)
return "kind" not in enc and enc["name"] == "Lost marker" and enc["description"] == "Custom from config"
---
True
