enc = {"name": "Treasure cache", "description": "Coins glint.", "outcomes": [{"type": "gold", "total": "3"}]}
result = encounters.process_encounter(enc, character())
return result["name"] == "Treasure cache" and "3" in result["outcome_text"]
---
True
---
name: process_encounter applies gold outcome

enc = {"name": "Empty", "description": "Nothing happens."}
result = encounters.process_encounter(enc, character())
return result["description"] == "Nothing happens." and result["outcome_text"] == ""
---
True
---
name: process_encounter handles encounter without outcomes

enc = {"name": "Fight", "description": "Steel flashes.", "combat_text": "> Combat Initiated!\nEnemies:\n* 1x Goblin"}
result = encounters.process_encounter(enc, character())
return "Steel flashes." in result["description"] and "Combat Initiated" in result["description"] and "Goblin" in result["description"]
---
True
---
name: process_encounter appends resolved combat text

enc = {
    "name": "Fight",
    "description": "Steel flashes.",
    "monsters": [{"name": "Spy"}],
    "combat_text": "```ansi\nCombat Initiated!\n```\nEnemies:\n* 1x Spy",
}
cfg = {"subsystems": {"travel": {"config": {}}}}
result = encounters.process_encounter(enc, character(), {"config": cfg})
desc = result["description"]
return "!i madd Spy" in desc and "!multiline" not in desc
---
True
---
name: process_encounter defaults combat prompt to single madd command

enc = {
    "name": "Fight",
    "description": "Steel flashes.",
    "monsters": [{"name": "Guard Captain", "count": 2}, {"name": "Mastiff", "count": 3}],
    "combat_text": "```ansi\nCombat Initiated!\n```\nEnemies:\n* 2x Guard Captain\n* 3x Mastiff",
}
cfg = {"subsystems": {"travel": {"config": {"combat_add_prompt": "madd_commands"}}}}
result = encounters.process_encounter(enc, character(), {"config": cfg})
desc = result["description"]
return "!multiline" in desc and '!i madd "Guard Captain" -n 2' in desc and "!i madd Mastiff -n 3" in desc
---
True
---
name: process_encounter uses multiline madd commands and quotes monsters

enc = {
    "name": "Fight",
    "description": "Steel flashes.",
    "monsters": [{"name": "Spy"}],
    "combat_text": "```ansi\nCombat Initiated!\n```\nEnemies:\n* 1x Spy",
}
cfg = {"subsystems": {"travel": {"config": {"combat_add_prompt": "off"}}}}
result = encounters.process_encounter(enc, character(), {"config": cfg})
return "!i madd Spy" not in result["description"] and "!combat" not in result["description"]
---
True
---
name: process_encounter can hide combat add prompt

enc = {
    "name": "Fight",
    "description": "Steel flashes.",
    "monsters": [{"name": "Spy"}],
    "combat_text": "```ansi\nCombat Initiated!\n```\nEnemies:\n* 1x Spy",
}
cfg = {"subsystems": {"travel": {"config": {"combat_add_prompt": "madd_commands"}}, "combat": {"commands": {"combat": True}}}}
result = encounters.process_encounter(enc, character(), {"config": cfg})
desc = result["description"]
return "Run `!combat`" in desc and "!i madd Spy" not in desc
---
True
---
name: process_encounter prefers combat hint when combat command is enabled

result = encounters.process_encounter(None, character())
return result["name"] == "Encounter"
---
True
---
name: process_encounter handles missing encounter

enc = {"name": "Scene", "description": "A wide view.", "thumb": "https://example.test/thumb.png", "image": "https://example.test/image.png"}
result = encounters.process_encounter(enc, character())
return result["thumb"] == "https://example.test/thumb.png" and result["image"] == "https://example.test/image.png"
---
True
---
name: process_encounter preserves embed image fields

enc = {"name": "Scene", "description": "A wide view.", "thumbnail": "https://example.test/thumb.png", "image_url": "https://example.test/image.png"}
result = encounters.process_encounter(enc, character())
return result["thumb"] == "https://example.test/thumb.png" and result["image"] == "https://example.test/image.png"
---
True
---
name: process_encounter accepts alternate embed image field names

cfg_fixture = {
    "world_data": {
        "default_location": "oakwood",
        "locations": {
            "oakwood": {"name": "Oakwood", "biome": "forest"},
        },
    },
}

seen = {}
enc = {
    "name": lambda ectx: ectx["current_location"]["name"],
    "description": lambda ectx: f"{ectx['activity']} in {ectx['biome']} with {len(ectx['args'])} arg",
    "thumb": lambda ectx: "https://example.test/thumb.png" if ectx["location_id"] == "oakwood" else None,
}
result = encounters.process_encounter(
    enc,
    character(),
    {"args": ["guidance"], "config": cfg_fixture, "activity": "enc", "biome": "forest"},
)
return result["name"] == "Oakwood" and result["description"] == "enc in forest with 1 arg" and result["thumb"] == "https://example.test/thumb.png"
---
True
---
name: process_encounter resolves callable fields with one context dict

enc = {
    "name": lambda ectx: "ok" if "current_location" in ectx and "biome" in ectx and ectx["biome"] == None else "bad",
    "description": lambda ectx: "no location" if ectx["current_location"] == None else "has location",
}
result = encounters.process_encounter(enc, character(), {"args": []})
return result["name"] == "ok"
---
True
---
name: process_encounter includes unset context keys as none

enc = {
    "name": "Old ranger mark",
    "description": "Three shallow cuts point toward a dry ford.",
    "rolls": [{"type": "check", "name": "Wisdom (Survival)", "ability": "wis", "dc": 0}],
}
result = encounters.process_encounter(enc, character(), {"args": [], "parsed_args": argparse("")})
return "Survival" in result["description"] and "Check" in result["description"] and "DC 0" in result["description"] and len(result["rolls"]) == 1
---
True
