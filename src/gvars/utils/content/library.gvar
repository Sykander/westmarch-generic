    "dungeon": "investigation",
    "dwarf": "history",
    "elves": "history",
    "engineering": "investigation",
    "fairy": "arcana",
    "fey": "arcana",
    "fish": "nature",
    "forage": "nature",
    "forest": "nature",
    "geography": "nature",
    "healing": "medicine",
    "history": "history",
    "intrigue": "investigation",
    "law": "history",
    "magic": "arcana",
    "math": "arcana",
    "mining": "nature",
    "mountain": "nature",
    "mystery": "investigation",
