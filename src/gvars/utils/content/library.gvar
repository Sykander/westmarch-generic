"""library.gvar - config-backed book search, recall, and comprehension."""

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(
    config = env.gvars.config,
    dicts = env.gvars.dicts,
    journeys = env.gvars.journeys,
    languages = env.gvars.languages,
    lists = env.gvars.lists,
    rolls = env.gvars.rolls,
)

CVAR_BOOK_COMPREHENSION = "wg_book_comprehension"
_DAY_SEC = 86400
_STALE_BASE_DAYS = 100
_STALE_KEEN_EXTRA_DAYS = 30
_MAX_CV_CHARS = 10000
_POOL_TARGET = 20
_TOPIC_SCAN_LIMIT = 60
_QUICK_BODY_LEN = 120
_MAX_TOPIC_WORDS = 8
_MAX_TOPIC_EXPANDED = 14
_READ_SKILLS_FALLBACK = ["history", "investigation", "nature", "religion", "arcana", "insight", "medicine"]
_RARITY_RANK = {"common": 0, "uncommon": 1, "rare": 2, "very rare": 3, "legendary": 4, "ancient": 4}
_TOPIC_READ_SKILL = {
    "adventure": "investigation",
    "alchemy": "arcana",
    "arcane": "arcana",
    "beasts": "nature",
    "cave": "nature",
    "city": "history",
