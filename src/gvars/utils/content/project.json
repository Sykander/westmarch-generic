{
  "name": "avrae-gvar-utils-content",
  "projectType": "library",
  "sourceRoot": "src/gvars/utils/content",
  "tags": ["scope:avrae", "type:gvar-utils"],
  "implicitDependencies": [
    "avrae-sourcemaps",
    "avrae-gvar-utils-core",
    "avrae-gvar-utils-config",
    "avrae-gvar-utils-catalogues"
  ],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "avraeGvarUtilBase",
        "{workspaceRoot}/src/gvars/utils/config/**/*",
        "{workspaceRoot}/src/gvars/utils/catalogues/**/*"
      ],
      "outputs": [],
      "options": {
        "command": "avrae-ls --log-level INFO --run-tests src/gvars/utils/content"
      }
    }
  }
}
