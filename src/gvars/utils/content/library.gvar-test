book = {
    "name": "Moonbridge Marginalia",
    "author": "Aerendyl",
    "written": "1368 DR",
    "rarity": "common",
    "language": "Elvish",
    "description": long_body,
    "tags": ["elves", "arcane"],
}
result = library.read_book(book, character(), argparse(""), "quick_read", [])
desc = result["comprehended_book"]["description"]
return result["language_comprehension_score"] == 100 and result["comprehension_score"] >= 70 and len(desc) > 120
