name: library searches inline configured books by title

cfg_fixture = {
    "subsystems": {"content": {"config": {"library_topic_source": "restricted", "allowed_topics": ["forest"]}}},
}
topics, error = library.resolve_search_topics(cfg_fixture, character(), argparse(""), ["desert"])
return len(topics) == 0 and "Allowed topics" in error
