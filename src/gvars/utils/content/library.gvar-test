cfg_fixture = {
    "books": [
        {
            "name": "Oakwood Almanac",
            "author": "Mira",
            "written": "1492 DR",
            "rarity": "common",
            "language": "Common",
            "type": "original",
            "description": "A practical guide to oak groves and forest roads.",
            "tags": ["forest", "history"],
            "content_link": "https://example.com/oakwood",
        },
    ],
}
hits = library.search_by_name(cfg_fixture, "oakwood", "")
return len(hits) == 1 and library.book_name(hits[0]) == "Oakwood Almanac"
