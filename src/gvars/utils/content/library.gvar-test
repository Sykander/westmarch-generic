name: library rejects restricted topics outside allow list

read_result = {
    "comprehended_book": {
        "name": "Oakwood Almanac",
        "metadata_line": "**Mira** · *1492 DR* · Common · common",
        "description": "A practical guide.",
    },
    "read_message": "You work through the passage.",
    "last_read_at": 0,
    "read_attempts": 1,
    "comprehension_score": 100,
    "book": {"content_link": "https://example.com/oakwood"},
}
return "Read the full text online" in library.read_display(read_result)
