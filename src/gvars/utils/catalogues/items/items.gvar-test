name: item catalogue uses configured inline entries

cfg_fixture = {
    "subsystems": {
        "crafting": {
            "config": {
                "catalogues": {
                    "items": {
                        "entries": [
                            {"name": "Custom Needle", "rarity": "mundane", "type": "Item", "value": "1 gp"},
                            {"name": "Custom Needle Case", "rarity": "mundane", "type": "Item", "value": "2 gp"},
                        ],
                    },
                },
            },
        },
    },
}
matches = items.name_matches(cfg_fixture, "items", "Custom")
return len(matches) == 2 and "Be more specific" in items.match_error("items", "Custom", matches)
---
True
