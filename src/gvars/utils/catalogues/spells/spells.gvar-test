---
name: spell catalogue uses configured inline entries

cfg_fixture = {
    "subsystems": {
        "crafting": {
            "config": {
                "catalogues": {
                    "spells": {
                        "entries": [
                            {"name": "Custom Spark", "level": 1, "school": "Evocation"},
                            {"name": "Custom Spark Shield", "level": 2, "school": "Abjuration"},
                        ],
                    },
                },
            },
        },
    },
}
matches = spells.name_matches(cfg_fixture, "spark")
return len(matches) == 2 and "Be more specific" in spells.match_error("spark", matches)
