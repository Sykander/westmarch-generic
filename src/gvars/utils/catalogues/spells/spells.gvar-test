name: spell catalogue resolves engine spell

cfg_fixture = {
    "subsystems": {
        "crafting": {
            "config": {
                "catalogues": {
                    "spells": {
                        "entries": [
                            {"name": "Custom Spark", "level": 1, "school": "Evocation"},
                        ],
                    },
                },
            },
        },
    },
}
hit = spells.search(cfg_fixture, "spark")
return hit != None and spells.spell_name(hit) == "Custom Spark"
