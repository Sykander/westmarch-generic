name: monster_name_matches uses hotpath buckets for goblin family lookups

hit = monsters.search(None, "Goblin")
return monsters.monster_image(hit) == "https://www.dndbeyond.com/avatars/thumbnails/30783/955/1000/1000/638062024584880857.png"
