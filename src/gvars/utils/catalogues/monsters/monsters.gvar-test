name: search returns None for unknown creature

cfg_fixture = {
    "world_data": {
        "monsters": [
            {"name": "Custom Beast", "cr": 2, "type_str": "Beast"},
        ],
    },
}
hit = monsters.search(cfg_fixture, "Custom")
return hit != None and hit["name"] == "Custom Beast"
