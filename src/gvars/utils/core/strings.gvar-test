name: strings gvar loads

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

empty_in = []
single_in = ["a"]
pair_in = ["a", "b"]
triple_in = ["a", "b", "c"]
expected_empty = ""
expected_single = "a"
expected_pair = "a and b"
expected_triple = "a, b and c"

out_empty = strings.get_readable_list(empty_in)
out_single = strings.get_readable_list(single_in)
out_pair = strings.get_readable_list(pair_in)
out_triple = strings.get_readable_list(triple_in)

expect(out_empty).to.be(expected_empty)
expect(out_single).to.be(expected_single)
expect(out_pair).to.be(expected_pair)
expect(out_triple).to.be(expected_triple)

return "ok"
---
"ok"
---
name: get_readable_list should format empty, single, and multiple items

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

n1 = 1
n2 = 2
n3 = 3
n11 = 11
n21 = 21

r1 = strings.get_ordinal_index(n1)
r2 = strings.get_ordinal_index(n2)
r3 = strings.get_ordinal_index(n3)
r11 = strings.get_ordinal_index(n11)
r21 = strings.get_ordinal_index(n21)

expect(r1).to.be("1st")
expect(r2).to.be("2nd")
expect(r3).to.be("3rd")
expect(r11).to.be("11th")
expect(r21).to.be("21st")

return "ok"
---
"ok"
---
name: get_ordinal_index should return correct ordinals

