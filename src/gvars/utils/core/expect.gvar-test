expect = expect.expect

def expect_to_raise_exception(func):
    try:
        func()
    except:
        return True
    else:
        err("Expected to raise exception")

def expect_to_not_raise_exception(func):
    try:
        func()
    except:
        err("Expected to not raise exception")
    else:
        return True

obj = { "a": True, "b": [0, 1], "c": { "d": "e" } }
assertion_a = lambda _ = None: expect(obj).to.have.property("a")
assertion_b = lambda _ = None: expect(obj).to.have.property("a").and_to.have.property("b")
assertion_c = lambda _ = None: expect(obj).to_have_property("b").which.has.length(2)
assertion_d = lambda _ = None: expect(obj).to.have.property("c").which.has.property("d").which.equals("e")


expect_to_not_raise_exception(assertion_a)
expect_to_not_raise_exception(assertion_b)
expect_to_not_raise_exception(assertion_c)
expect_to_not_raise_exception(assertion_d)

return "ok"
---
"ok"
---
name: expect should map to the correction assertions

