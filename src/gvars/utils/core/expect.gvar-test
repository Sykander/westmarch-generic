expect = expect.expect

def expect_to_raise_exception(func):
    try:
        func()
    except:
        return True
    else:
        err("Expected to raise exception")

def expect_to_not_raise_exception(func):
    try:
        func()
    except:
        err("Expected to not raise exception")
    else:
        return True

expect_to_raise_exception(lambda _ = None: expect("a").eq("b"))
expect_to_not_raise_exception(lambda _ = None: expect("a").eq("a"))

return "ok"
---
"ok"
---
name: expect.eq should throw an error if the values aren't equal

