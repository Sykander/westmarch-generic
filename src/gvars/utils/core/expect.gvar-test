throws_err = lambda _ = None: err("throw")
no_op = lambda _ = None: None


expect_to_raise_exception(lambda _ = None: expect(no_op).raise_exception())
expect_to_raise_exception(lambda _ = None: expect(no_op).raise_exception(AssertionError))
