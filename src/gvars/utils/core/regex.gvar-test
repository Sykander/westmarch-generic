name: compile should err on invalid patterns like compile_program

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

def expect_idx(pat, want_idx):
    errt, res = regex.diagnostic_compile(pat)
    expect(res == None).to.be(True)
    expect(errt != None).to.be(True)
    expect(errt[1]).to.be(want_idx)

expect_idx("a{", 1)
expect_idx("a{,", 2)
expect_idx("a{1x", 3)
expect_idx("a{1,a", 4)
expect_idx("a{1,2", 1)
expect_idx("\\", 0)
expect_idx("[\\D]", 1)
expect_idx("[z-a]", 2)
expect_idx("[a-9]", 2)
expect_idx("[", 0)
expect_idx("[a-\\]", 3)
expect_idx("[ab", 0)
expect_idx("[]", 1)
expect_idx(")", 0)
expect_idx("(ab", 0)
expect_idx("(?P<x>)", 0)
expect_idx("(?:ab", 0)
expect_idx("*", 0)
expect_idx("(", 0)

en, pc = regex.diagnostic_compile("/[]/")
expect(pc == None).to.be(True)
expect(en[1]).to.be(1)

ok_t, ok_rx = regex.diagnostic_compile("a")
expect(ok_t == None).to.be(True)
expect(ok_rx != None).to.be(True)
expect(ok_rx.pattern).to.be("a")

none_err, none_prog = regex.diagnostic_compile(None)
expect(none_prog == None).to.be(True)
expect(none_err[0]).to.be("pattern is None")
expect(none_err[1] == None).to.be(True)

return "ok"
---
"ok"
---
name: compile_program parse errors report correct pattern indices

