expect(rx.pattern).to.be("ab+")
expect(rx.groups).to.be(0)
expect(rx.fullmatch("abb")).to.be(True)
expect(rx.fullmatch("a")).to.be(False)
expect(rx.full_match("abb")).to.be(True)
expect(rx.match("abb")).to.be(3)
expect(rx.match("zabb")).to.be(None)
hit = rx.search("xxaby")
expect(hit.start).to.be(2)
expect(hit.end).to.be(4)
hit_pos = rx.search("xab", 1)
expect(hit_pos.start).to.be(1)
expect(hit_pos.end).to.be(3)
expect(rx.match_from("zabc", 1)).to.be(3)
expect(rx).to.have.property("match_from_captures")
expect(rx).to.have.property("search_captures")

return "ok"
