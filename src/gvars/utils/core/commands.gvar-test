name: get_command should omit args when args is None

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

tab_value = "a\tb"
newline_value = "a\nb"
expected_tab = '"a\tb"'
expected_newline = '"a\nb"'

quoted_tab = commands.get_quotes(tab_value)
quoted_newline = commands.get_quotes(newline_value)

expect(quoted_tab).to.be(expected_tab)
expect(quoted_newline).to.be(expected_newline)

return "ok"
---
"ok"
