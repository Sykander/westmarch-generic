"ok"
---
name: get_command should wrap args in appropriate quote marks

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

arg_a = "no_quotes"
arg_b = "use quotes"
arg_c = 'use single quotes"'
arg_d = "use double quotes"
arg_e = "use special quotes'" + '"'
expected_a = arg_a
expected_b = f'"{arg_b}"'
expected_c = f"'{arg_c}'"
expected_d = f'"{arg_d}"'
expected_e = f'《{arg_e}》'

quoted_a = commands.get_quotes(arg_a)
quoted_b = commands.get_quotes(arg_b)
quoted_c = commands.get_quotes(arg_c)
quoted_d = commands.get_quotes(arg_d)
quoted_e = commands.get_quotes(arg_e)

expect(quoted_a).to.be(expected_a)
expect(quoted_b).to.be(expected_b)
expect(quoted_c).to.be(expected_c)
expect(quoted_d).to.be(expected_d)
expect(quoted_e).to.be(expected_e)

return "ok"
---
"ok"
---
name: get_quotes should wrap args in appropriate quote marks

