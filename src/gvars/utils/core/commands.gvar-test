using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

actions = ["i", "a", "shortbow"]
args = [["-t", "GO1"], ["-d", "1d4"]]
expected_command = " ".join(actions) + " " + args[0][0] + " " + args[0][1] + " " + args[1][0] + " " + args[1][1]

command = commands.get_command(actions, args)

expect(command).to.be(expected_command)

return "ok"
---
"ok"
---
name: get_command should give a command string

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

actions = ['i"', "a'", "shortbow 12"]
args = [["-t", "GO1"], ["-d", "1d4"]]
expected_command = """'i"' "a'" "shortbow 12" """ + args[0][0] + " " + args[0][1] + " " + args[1][0] + " " + args[1][1]

command = commands.get_command(actions, args)

expect(command).to.be(expected_command)

return "ok"
