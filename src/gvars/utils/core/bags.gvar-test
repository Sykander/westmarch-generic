using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

char_name = "Aelar Wyn"

item = "Shortsword"
count_a = 1
count_b = 9
count_c = -1
count_d = -9
bag = "Equipment"
expected_modified_a = True
expected_message_a = f"{item} added to {char_name}'s bag {bag}."
expected_modified_b = True
expected_message_b = f"{count_b}x {item} added to {char_name}'s bag {bag}."
expected_modified_c = True
expected_message_c = f"{item} removed from {char_name}'s bag {bag}."
expected_modified_d = True
expected_message_d = f"{abs(count_d)}x {item} removed from {char_name}'s bag {bag}."

modified_a, message_a = bags.modify_bag(item, count_a, bag)
modified_b, message_b = bags.modify_bag(item, count_b, bag)
modified_c, message_c = bags.modify_bag(item, count_c, bag)
modified_d, message_d = bags.modify_bag(item, count_d, bag)

expect(message_a).to.be(expected_message_a)
expect(modified_a).to.be(expected_modified_a)
expect(message_b).to.be(expected_message_b)
expect(modified_b).to.be(expected_modified_b)
expect(message_c).to.be(expected_message_c)
expect(modified_c).to.be(expected_modified_c)
expect(message_d).to.be(expected_message_d)
expect(modified_d).to.be(expected_modified_d)

return "ok"
---
"ok"
---
name: modify_bag should add and remove items

