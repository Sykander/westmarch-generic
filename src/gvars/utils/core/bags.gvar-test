using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

char_name = "Aelar Wyn"

item = "Shortsword"
count = 1
bag = "Equipment"
expected_modified = True
expected_message = f"{item} added to {char_name}'s bag {bag}."

modified, message = bags.modify_bag(item, count, bag)

expect(modified).to.be(expected_modified)
expect(message).to.be(expected_message)

return "ok"
---
"ok"
---
name: modify_bag should run without error

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

char_name = "Aelar Wyn"

item = "Shortsword"
count = -100
bag = "Equipment"
expected_modified = False
expected_message = f"Couldn't update {char_name}'s bag {bag} with {count}x {item} because the new count would be {count}."

modified, message = bags.modify_bag(item, count, bag)

expect(message).to.be(expected_message)
expect(modified).to.be(expected_modified)

return "ok"
---
"ok"
---
name: modify_bag should return false if it can't modify the bag

