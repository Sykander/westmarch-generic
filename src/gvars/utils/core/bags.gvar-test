using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

char_name = "Aelar Wyn"

bag_name = "QA_IsolatedBag"
payload = {"token": 42}

bags.set_bag(bag_name, payload)
read_back = bags.get_bag(bag_name)

expect(read_back).to.have.property("token", 42)

return "ok"
---
"ok"
---
name: set_bag should create a bag and get_bag should read it back

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

char_name = "Aelar Wyn"

item = "Pebbles"
count = 0
bag = "QA_ZeroCountBag"
char_name_local = char_name

bags.set_bag(bag, {})
expected_message = f"0x {item} removed from {char_name_local}'s bag {bag}."

modified, message = bags.modify_bag(item, count, bag)

expect(modified).to.be(True)
expect(message).to.be(expected_message)

return "ok"
---
"ok"
---
name: modify_bag should treat zero count as removal wording
