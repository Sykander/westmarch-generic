using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

expected_prof_code = "pTools"

actual_code = tools.tool_prof_code

expect(actual_code).to.be(expected_prof_code)

return "ok"
