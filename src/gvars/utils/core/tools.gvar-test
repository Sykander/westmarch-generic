name: tools gvar loads

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

query = "Smith's Tools"

matches = tools.search_for_tool(query)

expect(matches).to.have.length(1)
expect(matches).to.have_element(query)

return "ok"
---
"ok"
---
name: search_for_tool should find exact tool names

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

query = "herbal"

