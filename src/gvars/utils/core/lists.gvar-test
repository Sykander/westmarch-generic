using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

input_a = "a"
input_b = 1
input_c = {}
input_d = []
input_e = (1, 2)

result_a = lists.is_list(input_a)
result_b = lists.is_list(input_b)
result_c = lists.is_list(input_c)
result_d = lists.is_list(input_d)
result_e = lists.is_list(input_e)

expect(result_a).to.be(False)
expect(result_b).to.be(False)
expect(result_c).to.be(False)
expect(result_d).to.be(True)
expect(result_e).to.be(False)

return "ok"
---
"ok"
---
name: is_list should give True if its a list and False otherwise

