using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

first_item = {"id": "a", "val": "b"}
second_item = {"id": "c", "val": "d"}
input = [first_item, second_item]
key = "id"

result = lists.to_dict(input, key)

expect(result).to.have.property(first_item[key]).which.has.property("val", first_item.val).and_to.have.property(key, first_item[key])
expect(result).to.have.property(second_item[key]).which.has.property("val", second_item.val).and_to.have.property(key, second_item[key])

return "ok"
---
"ok"
---
name: to_dict should convert the given list of objects into a dictionary

