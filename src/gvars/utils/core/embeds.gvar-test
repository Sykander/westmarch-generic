name: get_field Should give a properly formatted field

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

lots_of_text = "1234567890123456789012345678901234567890"
length = 20
expected_text = lots_of_text[0:17] + "..."

cut_text = embeds.format_to_length(lots_of_text, length)

expect(cut_text).to.be(expected_text)
expect(cut_text).to.have.length(length)

return "ok"
---
"ok"
---
name: format_to_length should give a string less than the given length

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

short = "hello"
limit = 20

result = embeds.format_to_length(short, limit)

expect(result).to.be(short)

return "ok"
---
"ok"
---
name: format_to_length should return content unchanged when shorter than limit

