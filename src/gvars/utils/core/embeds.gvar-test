using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

title = "Hello World!"
desc = "A really cool message!"
expected_command = f'embed -title "{title}" -desc "{desc}"'

embed_command = embeds.get_embed(title = title, desc = desc)

expect(embed_command).to.be(expected_command)

return "ok"
---
"ok"
---
name: get_embed should give an embed command string

using(env="d83fd033-128f-4b1c-a32c-7a9984ccf766")
using(assertions = env.gvars.expect)
expect = assertions.expect

title = "Hello World!"
desc = "A really cool message!"
fields = ["Field1", "Field2"]
footer = "cool footer"
image = "test"
thumb = "test"
color = "test"
timeout = 60
expected_command = f'embed -title "{title}" -desc "{desc}" -f {fields[0]} -f {fields[1]} -footer "{footer}" -image {image} -thumb {thumb} -color {color} -t {timeout}'

embed_command = embeds.get_embed(title = title, desc = desc, fields = fields, footer = footer, image = image, thumb = thumb, color = color, timeout = timeout)

expect(embed_command).to.be(expected_command)

return "ok"
---
"ok"
---
name: get_embed should accept all valid embed args

