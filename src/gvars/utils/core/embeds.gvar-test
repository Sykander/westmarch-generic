desc = "A really cool message!"
fields = ["Field1", "Field2"]
footer = "cool footer"
image = "test"
thumb = "test"
color = "test"
timeout = 60
expected_command = f'embed -title "{title}" -desc "{desc}" -f {fields[0]} -f {fields[1]} -footer "{footer}" -image {image} -thumb {thumb} -color {color} -t {timeout}'

get_embed = embeds.configure_get_embed(title = title, desc = desc, fields = fields, footer = footer, image = image, thumb = thumb, color = color, timeout = timeout)
