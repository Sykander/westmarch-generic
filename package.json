{
  "name": "westmarch-generic",
  "version": "1.0.0",
  "description": "Configurable westmarch-style Avrae workshop — server setup via svars and config gvars",
  "main": "index.js",
  "scripts": {
    "deploy": "nx run avrae-sourcemaps:deploy",
    "deploy:dev": "nx run avrae-sourcemaps:deploy-dev",
    "deploy:prod": "nx run avrae-sourcemaps:deploy-prod",
    "editor": "nx run editor:dev",
    "editor:dev": "nx run editor:dev",
    "editor:build": "nx run editor:build",
    "build": "nx run-many -t build --parallel 4",
    "types": "nx run-many -t types --parallel 4",
    "test": "nx run-many -t test --parallel 4",
    "lint": "npm run lint:check",
    "lint:check": "eslint . --cache --cache-location .cache/eslint/.eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .cache/eslint/.eslintcache && node utils/minify-gvar-json.js"
  },
  "author": "",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@eslint/json": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.0.0",
    "nx": "^23.0.1",
    "prettier": "^3.0.0",
    "publish-avrae": "^1.1.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
