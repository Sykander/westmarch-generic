{
  "name": "westmarch-generic",
  "version": "0.2.11",
  "description": "Configurable westmarch-style Avrae workshop — server setup via svars and config gvars",
  "main": "index.js",
  "scripts": {
    "deploy": "npm run deploy:dev",
    "deploy:dev": "publish-avrae deploy --sourcemap utils/sourcemap.dev.json",
    "deploy:prod": "publish-avrae deploy --sourcemap utils/sourcemap.prod.json",
    "generate-env": "npm run generate-env:dev && npm run generate-env:prod",
    "generate-env:dev": "publish-avrae generate-env --sourcemap utils/sourcemap.dev.json --output src/gvars/env.dev.gvar --version $npm_package_version --environment Development",
    "generate-env:prod": "publish-avrae generate-env --sourcemap utils/sourcemap.prod.json --output src/gvars/env.prod.gvar --version $npm_package_version --environment Production",
    "generate-vars": "node utils/generate-vars.js",
    "generate:monsters": "node utils/generate-monsters.js",
    "generate:items": "node utils/generate-items.js",
    "generate:spells": "node utils/generate-spells.js",
    "generate:books": "node utils/generate-books.js",
    "generate:recipes": "node utils/generate-recipes.js",
    "editor": "npm run editor:dev",
    "editor:dev": "npm --prefix editor run dev",
    "editor:build": "npm --prefix editor run build",
    "editor:test": "npm --prefix editor run test",
    "types": "npm --prefix editor run types",
    "lint": "npm run lint:check",
    "lint:check": "eslint . --cache --cache-location .cache/eslint/.eslintcache",
    "lint:fix": "eslint . --fix --cache --cache-location .cache/eslint/.eslintcache && node utils/minify-gvar-json.js",
    "avrae:test-utils": "npm run avrae:test-utils:config && npm run avrae:test-utils:catalogues && npm run avrae:test-utils:gameplay && npm run avrae:test-utils:systems",
    "avrae:test-utils:config": "avrae-ls --log-level INFO --run-tests src/gvars/utils/auth --run-tests src/gvars/utils/config --run-tests src/gvars/utils/display",
    "avrae:test-utils:catalogues": "avrae-ls --log-level INFO --run-tests src/gvars/utils/catalogues --run-tests src/gvars/utils/content",
    "avrae:test-utils:gameplay": "npm run avrae:test-utils:gameplay:encounters && npm run avrae:test-utils:gameplay:exploration && npm run avrae:test-utils:gameplay:world",
    "avrae:test-utils:gameplay:encounters": "avrae-ls --log-level INFO --run-tests src/gvars/utils/encounters",
    "avrae:test-utils:gameplay:exploration": "avrae-ls --log-level INFO --run-tests src/gvars/utils/exploration",
    "avrae:test-utils:gameplay:world": "avrae-ls --log-level INFO --run-tests src/gvars/utils/world",
    "avrae:test-utils:systems": "avrae-ls --log-level INFO --run-tests src/gvars/utils/core --run-tests src/gvars/utils/crafting --run-tests src/gvars/utils/economy --run-tests src/gvars/utils/misc --run-tests src/gvars/utils/pc",
    "avrae:test-config": "npm run avrae:test-utils:config",
    "avrae:test-gvars": "npm run avrae:test-utils",
    "avrae:test-aliases:content": "avrae-ls --log-level INFO --run-tests src/aliases/content --run-tests src/aliases/misc",
    "avrae:test-aliases:crafting": "avrae-ls --run-tests src/aliases/crafting --log-level INFO",
    "avrae:test-aliases:economy": "avrae-ls --log-level INFO --run-tests src/aliases/downtime --run-tests src/aliases/economy",
    "avrae:test-aliases:exploration": "npm run avrae:test-aliases:exploration:enc && npm run avrae:test-aliases:exploration:creatures && npm run avrae:test-aliases:exploration:gathering-a && npm run avrae:test-aliases:exploration:gathering-b",
    "avrae:test-aliases:exploration:enc": "avrae-ls --log-level INFO --run-tests src/aliases/exploration/enc.alias-test",
    "avrae:test-aliases:exploration:creatures": "avrae-ls --log-level INFO --run-tests src/aliases/exploration/hunt.alias-test --run-tests src/aliases/exploration/loot.alias-test",
    "avrae:test-aliases:exploration:gathering-a": "avrae-ls --log-level INFO --run-tests src/aliases/exploration/fish.alias-test --run-tests src/aliases/exploration/forage.alias-test",
    "avrae:test-aliases:exploration:gathering-b": "avrae-ls --log-level INFO --run-tests src/aliases/exploration/lumber.alias-test --run-tests src/aliases/exploration/mine.alias-test",
    "avrae:test-aliases:travel": "avrae-ls --run-tests src/aliases/travel --log-level INFO",
    "avrae:test-aliases:westmarch": "avrae-ls --run-tests src/aliases/westmarch --log-level INFO",
    "sourcemap:dev-check": "publish-avrae check-config --sourcemap utils/sourcemap.dev.json",
    "sourcemap:prod-check": "publish-avrae check-config --sourcemap utils/sourcemap.prod.json",
    "sourcemap:compare-check": "publish-avrae compare-config utils/sourcemap.dev.json utils/sourcemap.prod.json"
  },
  "author": "",
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@eslint/json": "^2.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.0.0",
    "prettier": "^3.0.0",
    "publish-avrae": "^1.1.4",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0"
  }
}
